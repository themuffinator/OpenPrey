	windowDef bg1 {
		rect		0, 0, 640, 480
		backcolor		1, 1, 1, 0
		matcolor		0.7, 0.7, 1, 0.8
		background	"guis/assets/non_interact/autopsyscan/bgjen"
		onTime 0 {
			transition "bg1::rect" "0, 0, 640, 480" "5, 5, 630, 470" "200" ;
		}
		onTime 200 {
			transition "bg1::rect" "5, 5, 630, 470" "0, 0, 640, 480" "200" ;
		}
		onTime 400 {
			resetTime "0";
		}
	}	


	windowDef bg3 {
		rect		0, 0, 640, 480
		backcolor		1, 1, 1, 0
		matcolor		1, 1, 1, 1
		background	"guis/assets/non_interact/autopsyscan/bgjen"

	}	
	
	windowDef scan6 {

		rect		482, 327, 80, 200
		backcolor	1, 1, 1, 0 
		forecolor	1, 1, 1, 1 
		text		"#str_41122"
		font		"fonts/alien"
		textscale	0.45
		notranslation	0
		onTime 0 {
			transition "scan6::forecolor" "0.8, 0.7, 0.3, 0.6 " "0.9, 0.8, 0.5, 1 " "200" ;
		}
		onTime 200 {
			transition "scan6::forecolor" "0.9, 0.8, 0.5, 1 " "0.8, 0.7, 0.3, 0.6 " "200" ;
		}
		onTime 400 {
			resetTime "0";
		}

	}	
	windowDef scan {
		rect		0, 0, 640, 480
		backcolor	0, 0, 0, 0
		matcolor	1, 1, 1, 0.2
		background	"guis/assets/scanline/g_scan"
	}
	windowDef scan2 {
		rect		0, 0, 640, 480
		backcolor	0, 0, 0, 0
		matcolor	1, 1, 1, 1
		background	"guis/assets/scanline/g_scan2"
	}

	
	
	// Damage overlays, visible when console has been damaged
	windowDef damageOverlayStatic {
		rect		0, 0, 640, 480
		matcolor	1, 1, 1, 1
		background	"guis/assets/damageOverlayStatic"
		visible		"gui::damaged"
	}

	windowDef damageOverlayVHold {
		rect		0, 0, 640, 480
		matcolor	1, 1, 1, 1
		background	"guis/assets/damageOverlayVHold"
		visible		"gui::damaged"
	} 
}