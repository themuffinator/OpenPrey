// These define the 2 colors to fade between for the side panels
#define PANEL_LOW_R		0.77
#define PANEL_LOW_G		0.17
#define PANEL_LOW_B		0.0
#define PANEL_LOW_A		1
#define PANEL_HIGH_R	1
#define PANEL_HIGH_G	1
#define PANEL_HIGH_B	0
#define PANEL_HIGH_A	1

// These define the properties of the 2 twitcher displays on top
#define TWITCHER_LEFT_X				108
#define TWITCHER_RIGHT_X			332
#define TWITCHER_Y					-15

#define TWITCHER_WIDTH				50
#define TWITCHER_HEIGHT				50
#define TWITCHER_HALFWIDTH			(TWITCHER_WIDTH*0.5)
#define TWITCHER_HALFHEIGHT			(TWITCHER_HEIGHT*0.5)
#define TWITCHER_CAGE_WIDTH			200		//	4*WIDTH?
#define TWITCHER_CAGE_HEIGHT		150		//	3*HEIGHT?
#define TWITCHER_CAGE_HALFWIDTH		(TWITCHER_CAGE_WIDTH*0.5)
#define TWITCHER_CAGE_HALFHEIGHT	(TWITCHER_CAGE_HEIGHT*0.5)

windowDef desktop {
	rect			0, 0, 640, 480
	backcolor		0, 0, 0, 0
	nocursor		1
	noninteractive	1

	//--------------------------------------------------------------------
	//			On/Off logic
	//--------------------------------------------------------------------
	onNamedEvent TurnOff {
		resettime "PowerOffAnim" "0";
		set "cmd" "turnoff" ;
	}
	onNamedEvent TurnOn {
		resettime "PowerOnAnim" "0";
		set "cmd" "turnon" ;
	}

	windowDef BlackOut {
		rect		0, 0, 640, 480
		backcolor	0, 0, 0, 1
		visible		0
	}

	windowDef PowerOffAnim {
		rect		0, 0, 0, 0
		noTime		1
		onTime 0 {
			set "OuterBackgroundL::visible" "0" ;
			set "OuterBackgroundR::visible" "0" ;
			set "TwitcherL::visible" "0" ;
			set "TwitcherR::visible" "0" ;
			set "BlackOut::visible" "1" ;
			transition "BlackOut::rect" "130 10 380 420" "320 240 0 0" "300";
		}
	}
	
	windowDef PowerOnAnim {
		rect		0, 0, 0, 0
		noTime		1
		onTime 0 {
		}
		onTime 300 {
			set "OuterBackgroundL::visible" "1" ;
			set "OuterBackgroundR::visible" "1" ;
			set "TwitcherL::visible" "1" ;
			set "TwitcherR::visible" "1" ;
		}
	}


	// Procedural effects

