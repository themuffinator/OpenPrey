*/

	windowDef OuterBackgroundL {
		rect		0, 14, 110, 470
		background	"guis/assets/jukebox/sideart.tga"
		matcolor	PANEL_HIGH_R * "gui::amplitude" + PANEL_LOW_R * (1 - "gui::amplitude"),
					PANEL_HIGH_G * "gui::amplitude" + PANEL_LOW_G * (1 - "gui::amplitude"),
					PANEL_HIGH_B * "gui::amplitude" + PANEL_LOW_B * (1 - "gui::amplitude"),
					PANEL_HIGH_A * "gui::amplitude" + PANEL_LOW_A * (1 - "gui::amplitude")
	}
	windowDef OuterBackgroundR {
		rect		530, 14, -110, 470
		background	"guis/assets/jukebox/sideart.tga"
		matcolor	PANEL_HIGH_R * "gui::amplitude" + PANEL_LOW_R * (1 - "gui::amplitude"),
					PANEL_HIGH_G * "gui::amplitude" + PANEL_LOW_G * (1 - "gui::amplitude"),
					PANEL_HIGH_B * "gui::amplitude" + PANEL_LOW_B * (1 - "gui::amplitude"),
					PANEL_HIGH_A * "gui::amplitude" + PANEL_LOW_A * (1 - "gui::amplitude")
	}

	windowDef TwitcherAnim {
		rect		0, 0, 0, 0
		backcolor	0, 0, 0, 0
		notime		1
		
		onTime 5000 {
			transition "TwitcherL::rect" "-40 0 200 150" "480 0 200 150" "1000" "200" "200" ;
			transition "TwitcherR::rect" "480 0 200 150" "-40 0 200 150" "1000" "200" "200" ;
		}
		onTime 10000 {
			transition "TwitcherR::rect" "-40 0 200 150" "480 0 200 150" "1000" "200" "200" ;
			transition "TwitcherL::rect" "480 0 200 150" "-40 0 200 150" "1000" "200" "200" ;
		}
		onTime 15000 {
			transition "TwitcherL::rect" "-40 0 200 150" "-40 100 200 150" "1000" "200" "200" ;
			transition "TwitcherR::rect" "480 0 200 150" "480 100 200 150" "1000" "200" "200" ;
		}
		onTime 20000 {
			transition "TwitcherL::rect" "-40 100 200 150" "-40 0 200 150" "1000" "200" "200" ;
			transition "TwitcherR::rect" "480 100 200 150" "480 0 200 150" "1000" "200" "200" ;
			resetTime "0";
		}
	}

	windowDef TwitcherL {
		rect		TWITCHER_LEFT_X, TWITCHER_Y, TWITCHER_CAGE_WIDTH, TWITCHER_CAGE_HEIGHT
		backcolor	0, 0, 0, 0
		
		windowDef TwitcherbackL {
			rect		-5, 28, 195, 90
			matcolor	1, 1, 1, 1
			background	"guis/assets/jukebox/twitchscreen.tga"
		}
		windowDef Twitcher1 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0.7", 0.7, "gui::amplitude", 1
			shear		0, "gui::amplitude"
			rotate		time*0.2
		}
		windowDef Twitcher2 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		0, "gui::amplitude"*2
			rotate		time * -0.2
		}

		windowDef Twitcher3 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		0, 0-"gui::amplitude"
			rotate		time*0.2
		}
		windowDef Twitcher4 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		0, 0-"gui::amplitude"*2
			rotate		time * -0.2
		}

		windowDef Twitcher5 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		"gui::amplitude", 0
			rotate		time*0.2
		}
		windowDef Twitcher6 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		"gui::amplitude", 0
			rotate		time * -0.2
		}
		
		windowDef TwitcherOverlay {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			matcolor	1, 0, 0, 1
			background	"guis/assets/jukebox/twitcherback.tga"
			rotate		time * -0.2
		}
	}

	windowDef TwitcherR {
		rect		TWITCHER_RIGHT_X, TWITCHER_Y, TWITCHER_CAGE_WIDTH, TWITCHER_CAGE_HEIGHT
		backcolor	0, 0, 0, 0
		
		windowDef TwitcherbackR {
			rect		10, 28, -195, 90
			matcolor	1, 1, 1, 1
			background	"guis/assets/jukebox/twitchscreen.tga"
		}
		windowDef TwitcherR1 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0.7", 0.7, "gui::amplitude", 1
			shear		0, "gui::amplitude"
			rotate		time*0.2
		}
		windowDef TwitcherR2 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		0, "gui::amplitude"*2
			rotate		time * -0.2
		}

		windowDef TwitcherR3 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		0, 0-"gui::amplitude"
			rotate		time*0.2
		}
		windowDef TwitcherR4 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		0, 0-"gui::amplitude"*2
			rotate		time * -0.2
		}

		windowDef TwitcherR5 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		"gui::amplitude", 0
			rotate		time*0.2
		}
		windowDef TwitcherR6 {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			background	"guis/assets/jukebox/twitcher"
			backcolor	0, 0, 0, 0
			matcolor	"0", 1-"gui::amplitude", "gui::amplitude", 1
			shear		"gui::amplitude", 0
			rotate		time * -0.2
		}

		windowDef TwitcherOverlayR {
			rect		TWITCHER_CAGE_HALFWIDTH-(TWITCHER_HALFWIDTH*"gui::amplitude"), TWITCHER_CAGE_HALFHEIGHT-(TWITCHER_HALFHEIGHT*"gui::amplitude"), TWITCHER_WIDTH*"gui::amplitude", TWITCHER_HEIGHT*"gui::amplitude"
			matcolor	1, 0, 0, 1
			background	"guis/assets/jukebox/twitcherback.tga"
			rotate		time * -0.2
