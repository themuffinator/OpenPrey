#define TABLECOLOR		0,0,0,0
// Grid is 19 x 21, each cell is 20x20 units
//
// gui::score
// gui::lives
// gui::level
// gui::player_x
// gui::player_y
// gui::player_angle		rotation in degrees
// gui::player_moving		whether player is moving
// gui::player_vis
// gui::monster1_x
// gui::monster1_y
// gui::monster1_pu			powerup time remaining
// gui::monster1_visible
// gui::fruit_x
// gui::fruit_y
// gui::fruit_vis

windowDef Desktop {
	rect		0, 0, 640, 480
	backcolor	0, 0, 0, 0
	nocursor	1

	onNamedEvent gameover {
		set "GameOver::textscale" "0.2" ;
		transition "GameOver::textscale" "0.2" "3.2" "4000" ;
		resettime "GameOver" "0";
	}

	//--------------------------------------------------------------------
	//			On/Off logic
	//--------------------------------------------------------------------
	onNamedEvent TurnOff {
		resettime "PowerOffAnim" "0";
		set "cmd" "reset" ;
	}
	onNamedEvent TurnOn {
		resettime "PowerOnAnim" "0";
	}

	windowDef BlackOut {
		rect		130, 10, 380, 420
		backcolor	0, 0, 0, 0
		matcolor	1, 1, 1, 0.2
		background	"guis/assets/arcade/gamelayout"
	}

	windowDef PowerOffAnim {
		rect		0, 0, 0, 0
		noTime		1
		onTime 0 {
			set "desktop::noninteractive" "1" ;
			set "WholeScreen::visible" "0" ;
			set "BlackOut::visible" "1" ;
			transition "BlackOut::rect" "130 10 380 420" "320 240 0 0" "300";
		}
	}
	
	windowDef PowerOnAnim {
		rect		0, 0, 0, 0
		noTime		1
		onTime 0 {
			transition "BlackOut::rect" "320 240 0 0" "130 10 380 420" "300";
		}
		onTime 300 {
			set "desktop::noninteractive" "0" ;
			set "WholeScreen::visible" "1" ;
			set "BlackOut::visible" "0" ;
		}
	}


	//--------------------------------------------------------------------
	// Game screen
	//--------------------------------------------------------------------
