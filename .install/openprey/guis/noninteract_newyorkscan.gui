//right hand ticks
	windowDef meter {
		rect        484, 100, 32, 0
		backcolor    0, 0, 0, 0
		matcolor    1, 0.1, 0.0, 0.7
		background    "guis/assets/mutate/1/tick2"
		visible        0
		onTime 0 {
		}

		onTime 500 {
			transition "meter::rect" "115, 238, 32, 0" "115, 238, 32, -66" "400" ;
			set "meter::visible" "1" ;
		}
		onTime 2000 {
			resetTime "0";
			transition "meter::rect" "115, 238, 32, -66" "115, 238, 32, 0" "0" ;
			set "meter::visible" "0" ;
		}
	}		

//bottom ticks
	windowDef meter2 {
		rect        75, 100, 32, 0
		backcolor    0, 0, 0, 0
		matcolor    1, 0.1, 0.0, 1
		background    "guis/assets/mutate/1/tick2"
		visible        0
		onTime 0 {
		}

		onTime 1000 {
			transition "meter2::rect" "165, 5, 370, 0" "165, 5, 370, -65" "400" ;
			set "meter2::visible" "1" ;
		}
		onTime 2000 {

			transition "meter2::rect" "165, 5, 370, -65 " "165, 5, 370, 0" "700" ;
			resetTime "0";
//			set "meter2::visible" "0" ;
		}
	}
	
