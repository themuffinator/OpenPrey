//NEW YORK CITY SCAN



windowDef Desktop {
		rect		0, 0, 640, 480
//		backcolor	0, 0.1, 0.3, 1
		backcolor	0, 0, 0, 1

	windowDef colorbackb {
		rect		0, 0, 640, -480 
		background	"guis/assets/non_interact/newyorkscan/newyork"
		
		
	}
	windowDef colorback {
		rect		0, 0, 640, 480 

		onTime 0 {
		}

		onTime 900 {
			transition "colorback::backcolor" "0, 0.1, 0.3, 0.7" "1, 0.1, 0.0, 0.5" "1000" ;
		}
		onTime 2000 {
			transition "colorback::backcolor" "1, 0.1, 0.0, 0.5" "0, 0.1, 0.3, 0.7" "400" ;
		}
		onTime 3100 {
			transition "colorback::backcolor" "0, 0.1, 0.3, 0.7" "1, 0.1, 0.0, 0.5" "1000" ;
		}
		onTime 4200 {
			transition "colorback::backcolor" "1, 0.1, 0.0, 0.5" "0, 0.1, 0.3, 0.7" "300" ;
			resetTime "0";
		}		
		
	}	
	
	windowDef newyork {
		rect		20, 56, 610, 420 
		backcolor	1, 1, 1, 0 
		forecolor	1, 1, 1, 1 
		matcolor	1, 0.6, 0.2, 1
		background	"guis/assets/non_interact/newyorkscan/newyork"
		visible		1
		onTime 0 {
		}

		onTime 900 {
			transition "newyork::matcolor" "1, 1, 1, 1" "1, 0.1, 0.0, 1" "1000" ;
			transition "newyork::rect"	"410, 286, 200, 100"  "150, 96, 840, 420"  "1000" ;
		}
		onTime 2000 {
			transition "newyork::matcolor" "1, 0.0, 0.1, 1" "1, 1, 1, 1" "400" ;
			transition "newyork::rect"	"150, 96, 840, 420"  "380, 126, 580, 290"  "400" ;
		}
		onTime 3100 {
			transition "newyork::matcolor" "1, 1, 1, 1" "1, 0.1, 0.0, 1" "1000" ;
			transition "newyork::rect"	"380, 126, 580, 290"  "100, 216, 580, 290"  "1000" ;
		}
		onTime 4200 {
			transition "newyork::matcolor" "1, 0.1, 0.0, 1" "1, 1, 1, 1" "300" ;
			transition "newyork::rect"	"100, 216, 580, 290"  "410, 286, 200, 100"  "300" ;
			resetTime "0";
		}		
		
	}
	
