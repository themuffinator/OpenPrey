{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch OpenPrey MP",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\.install\\OpenPrey-client_x64.exe",
      "args": [
        "+set",
        "logFile",
        "2",
        "+set",
        "logFileName",
        "logs/openprey.log",
        "+set",
        "developer",
        "1",
        "+set",
        "r_fullscreen",
        "0",
        "+set",
        "fs_savepath",
        "${workspaceFolder}\\.home",
        "+set",
        "fs_devpath",
        "${workspaceFolder}\\.install",
        "+set",
        "fs_game",
        "openprey",
        "+set",
        "si_gameType",
        "DM"
      ],
      "cwd": "${workspaceFolder}\\.install",
      "console": "integratedTerminal"
    },
    {
