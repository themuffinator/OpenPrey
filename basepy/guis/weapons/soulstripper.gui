// gui::type			type of ammo currently installed
// gui::leeching		whether currently leeching
// gui::souls			how many canisters total held [1..3]
// gui::meter			charge meter level [0..1]
// gui::leechtype		type of ammo being leeched while leeching
// gui::soulpercentageA	percent of ammo in soul A available [0..1]
// gui::soulpercentageB	percent of ammo in soul B available [0..1]
// gui::soulpercentageC	percent of ammo in soul C available [0..1]

#define COLOR_WHITE				1, 1, 1, 1
#define COLOR_YELLOW			1, 0.7, 0.3, 1
#define COLOR_BLUE				0.6, 0.65, 1, 1
#define COLOR_AQUA				0.6, 0.9, 1, 1
#define COLOR_LIGHTAQUA		0.85, 1, 1, 1
#define COLOR_RED					1, 0.3, 0.2, 1
#define COLOR_ORANGE			1, 0.7, 0.3, 1
#define COLOR_LIGHTYELLOW	1, 0.9, 0.75, 1

windowDef Desktop {
	rect			0, 0, 640, 480
	backcolor		0, 0, 0, 0

//---------------------------------------------------------	
//   Draw meter
//---------------------------------------------------------	
	windowDef crop_meter {
		rect		0, 100, 580 * ("gui::meter"), 240
		visible		"gui::leeching"

		windowDef meterType1 {	// Plasma
			rect		0, 0, 580, 240
			matcolor	1, 1, 1, 1
			background	"guis/assets/weapons/soulstripper/meter_plasma"
			visible		("gui::leechtype" == 1)
		}
		windowDef meterType2 {	// Railgun
			rect		0, 0, 580, 240
			matcolor	1, 1, 1, 1
			background	"guis/assets/weapons/soulstripper/meter_lightning"
			visible		("gui::leechtype" == 2)
		}
		windowDef meterType3 {	// Sunbeam
			rect		0, 0, 580, 240
			matcolor	1, 1, 1, 1
			background	"guis/assets/weapons/soulstripper/meter_sunbeam"
			visible		("gui::leechtype" == 3)
		}
		windowDef meterType4 {	// Freeze
			rect		0, 0, 580, 240
			matcolor	1, 1, 1, 1
			background	"guis/assets/weapons/soulstripper/meter_freeze"
			visible		("gui::leechtype" == 4)
		}
	}
	
