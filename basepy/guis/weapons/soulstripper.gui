	windowDef Ticks_plasma {
		rect		0, 0, 640, 480
		visible		("gui::type" == 1)
		windowDef line1b {	// Leftmost (bottom)
			rect		110, 140, 32, 135
			backcolor	0, 0, 0, 0
			forecolor	1, 1, 1, 1
			matcolor	COLOR_RED
			background	"guis/assets/weapons/soulstripper/block"
			visible		("gui::leeching" == 0 && "gui::soulpercentageC" > 0.66)
		}
