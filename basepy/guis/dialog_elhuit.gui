	windowDef bg_spherebg {
		rect		45, 47, 440, 380
		matcolor	1, 1, 1, 1
		background	"guis/assets/dialog_elhuit/bg_spherebg"
	}
	windowDef tag {
		rect		355, 300, 110, 80
		matcolor	1, 1, 1, 1
		background	"guis/assets/dialog_elhuit/bg_sphere_tag"
	}
	windowDef tag2 {
		rect		50, 260, 80, 60
		matcolor	1, 1, 1, 1
		background	"guis/assets/dialog_elhuit/bg_sphere_tag2"
	}
	windowDef cir
	{
		rect		60, 185, 380, 100
		backcolor	0, 0, 0, 0
		forecolor	1, 1, 1, 1
		matcolor	1, 0.7, 0.4, 0.3
		background	"guis/assets/countdown/cir2"
		rotate time * -0.03
	}
	windowDef cir2
	{
		rect		60, 185, 380, 100
		backcolor	0, 0, 0, 0
		forecolor	1, 1, 1, 1
		matcolor	1, 0.7, 0.4, 0.2
		background	"guis/assets/countdown/cir2"
		visible		1
		rotate time * -0.1
	}
	windowDef cir_1
	{
		rect		125, 105, 240, 250
		backcolor	0, 0, 0, 0
		forecolor	1, 1, 1, 1
		matcolor	1, 0.7, 0.2, 1
		background	"guis/assets/non_interact/earthscan/cir_1"
		visible		1
		onTime 0 {
			transition "cir_1::rect" "125 105 240 250" "65 45 370 380" "1000" ;
			transition "matcolor" "1 0.8 0.2 0" "1 0.8 0.2 0.5" "700" ;
		}
		onTime 1000 {
			transition "matcolor" "1 0.8 0.2 0.5" "1 0.8 0.2 0" "700" ;
		}
		onTime 1400 {
			resetTime "0";
		}
	}
	windowDef cir_2
	{
		rect		125, 105, 240, 250
		backcolor	0, 0, 0, 0
		forecolor	1, 1, 1, 1
		matcolor	1, 0.7, 0.2, 1
		background	"guis/assets/non_interact/earthscan/cir_1"
		visible		1
		onTime 350 {
			transition "cir_2::rect" "125 105 240 250" "65 45 370 380" "1000" ;
			transition "matcolor" "1 0.8 0.2 0" "1 0.8 0.2 0.5" "700" ;
		}
		onTime 1050 {
			transition "matcolor" "1 0.8 0.2 0.5" "1 0.8 0.2 0" "700" ;
		}
		onTime 1450 {
			resetTime "0";
		}
	}	
	windowDef Rotate_rect {
		rect 		115, 75, 265, 320
		matcolor	0 , 0, 1, 1 
		visible 1
		rotate time * 0.05
		
		windowDef circ {
			rect 		5, 25, 30, 30
			matcolor 	1, 0.5, 0.3, 1
			background	"guis/assets/non_interact/earthscan/target_2"
			visible 1
		}
		onTime 50 {
			transition "matcolor" "1 0.8 0.2 0" "1 0.8 0.2 0.4" "300" ;
		}
		onTime 650 {
			transition "matcolor" "1 0.8 0.2 0.4" "1 0.8 0.2 0" "300" ;
		}
		onTime 1050 {
			resetTime "0";
		}
	}
	windowDef bg_sphere {
		rect		100, 85, 300, 300
		matcolor	1, 1, 1, 1
		background	"guis/assets/dialog_elhuit/bg_sphere"
		visible		1
	}
	
	
