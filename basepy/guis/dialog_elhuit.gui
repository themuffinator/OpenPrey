			transition "matcolor" "1 1 1 1" "1 1 1 0" "200" ;
		}
		onTime 650 {
			transition "matcolor" "1 1 1 0" "1 1 1 1" "100" ;
		}
		onTime 2000 {
			resetTime "0";
		}
	}
	windowDef bg_keeper2 {
		rect		0, 0, 640, 480
		matcolor	1, 1, 1, 0
		background	"guis/assets/dialog_elhuit/bg_keeper2"
	//	visible		1
	}

