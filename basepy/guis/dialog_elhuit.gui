	windowDef bg_keeper {
		rect		40, 45, 450, 385
		matcolor	1, 1, 1, 0
		background	"guis/assets/dialog_elhuit/bg_keeper"
	}
	windowDef outlineWindow {
		rect		40, 45, 450, 385
		float clipZ 0
		visible		0

		onTime 0 {
			transition "clipZ" "0" "1" "950";
		}
		onTime 1000 {
			transition "clipZ" "1" "0" "10";
		}
		onTime 1500 {
			resetTime "0";
		}
		windowDef outlineClip {
			rect		0, 385 * (1 - "outlineWindow::clipZ"), 450, 385
			
			windowDef outlineFill {
				rect		450, 385 * "outlineWindow::clipZ", 450, 385
				backcolor	0, 0, 0, 0
				matcolor	0.5, 0.8, 1, 0.8 * jitter1[time*0.05]
				background	"guis/assets/dialog_elhuit/bg_keeper_outline"
				invertrect	1
			}
		}
	}
	windowDef keeper_tag {
		rect		70, 195, 80, 60
		matcolor	1, 1, 1, 0
		background	"guis/assets/dialog_elhuit/bg_sphere_tag2"
	}
	windowDef keeper_tag2 {
		rect		260, 140, -110, -90
		matcolor	1, 1, 1, 0
		background	"guis/assets/dialog_elhuit/bg_sphere_tag2"
	}
	windowDef keeper_tag3 {
