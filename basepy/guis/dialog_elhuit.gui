//------------------------------------------------------------
//	Overlay rects
//------------------------------------------------------------

	windowDef static {
		rect		0, 0, 640, 480
		backcolor	0, 0, 0, 0
		forecolor	1, 1, 1, 1
		matcolor	1, 1, 1, 0.1
