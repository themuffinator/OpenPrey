	windowDef bg {
		rect		0, 0, 640, 480
		matcolor	1, 1, 1, 1
		background	"guis/assets/dialog_elhuit/bg"
		visible		1
	}
	windowDef bg_mainback {
		rect		40, 45, 450, 385
		matcolor	1, 1, 1, 0
		background	"guis/assets/dialog_elhuit/bg_main"
