		}
		onTime 2900 {
			transition "scannerman::rect" "427, 150, 50, 50 " "427, 280, 50, 50 " "1200" ;		
		}
		onTime 4100 {
			transition "scannerman::rect" "427, 280, 50, 50 " "420, 300, 50, 50 " "300" ;		
		}
		onTime 4400 {
			transition "scannerman::rect" "420, 300, 50, 50 " "400, 320, 50, 50 " "300" ;	
		}
		onTime 4700 {
			transition "scannerman::rect" "400, 320, 50, 50 " "380, 335, 50, 50 " "300" ;	
		}
		onTime 5000 {
			transition "scannerman::rect" "380, 335, 50, 50 " "290, 335, 50, 50 " "1000" ;	
		}
		onTime 6000 {
			resetTime "0";
		}
	}
	
