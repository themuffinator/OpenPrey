//HUMANS ON SLABS

windowDef desktop {
	rect			0, 0, 640, 480
	backcolor		0, 0, 0, 0



	
	windowDef bg2 {
		rect		0, 0, 640, 480
		backcolor		0.1, 0.1, 1, 0
//		forecolor		1, 1, 1, 1

		background	"guis/assets/non_interact/autopsyscan/bgjen2"
		

	}

	
	windowDef movement {
		
		rect	0, 0, 640, 480
		matcolor  1, 1, 1, 0
		background	"guis/assets/non_interact/autopsyscan/slabshot2"


		onTime 0 {
			transition "movement::rect" "0, 0, 800, 600" "280, 0, 800, 600" "1000" ;
			transition "movement::matcolor" "0.6, 0.8, 1, 0.1" "0.6, 0.8, 1, 0.3" "1000" ;
			}		

		onTime 2000 {
		
			transition "movement::matcolor" "0.6, 0.8, 1, 0.3" "0.6, 0.8, 1, 0.1" "1000" ;	
			transition "movement::rect" "280, 0, 800, 600" "280, -160, 800, 600"  "1000" ;
			}
		onTime 4000 {
		
			transition "movement::matcolor" "0.6, 0.8, 1, 0.1" "0.6, 0.8, 1, 0.3" "1000" ;	
			transition "movement::rect" "280, -160, 800, 600" "0, -160, 800, 600"  "1000" ;
			}
		onTime 6000 {
		
			transition "movement::matcolor" "0.6, 0.8, 1, 0.3" "0.6, 0.8, 1, 0.1" "1000" ;	
			transition "movement::rect" "0, -160, 800, 600" "0, 0, 800, 600"  "1000" ;
			}
		onTime 8000 {
			resetTime "0";
		}
	}
	windowDef movement2 {
		
		rect	0, 0, 640, 480
		matcolor  1, 1, 1, 0
		background	"guis/assets/non_interact/autopsyscan/slabshot2"


		onTime 0 {

			transition "movement2::rect" "280, -160, -800, -600" "0, -160, -800, -600"  "1000" ;
			transition "movement2::matcolor" "0.6, 0.8, 1, 0.3" "0.6, 0.8, 1, 0.1" "1000" ;
			}		

		onTime 2000 {
		
			transition "movement2::matcolor" "0.6, 0.8, 1, 0.1" "0.6, 0.8, 1, 0.3" "1000" ;	
			transition "movement2::rect" "0, -160, -800, -600" "0, 0, -800, -600"  "1000" ;
			}
		onTime 4000 {
		
			transition "movement2::matcolor" "0.6, 0.8, 1, 0.3" "0.6, 0.8, 1, 0.1" "1000" ;	
			transition "movement2::rect" "0, 0, -800, -600" "280, 0, -800, -600" "1000" ;
			}
		onTime 6000 {
		
			transition "movement2::matcolor" "0.6, 0.8, 1, 0.1" "0.6, 0.8, 1, 0.3" "1000" ;	
			transition "movement2::rect" "280, 0, -800, -600" "280, -160, -800, -600"  "1000" ;
			}
		onTime 8000 {
			resetTime "0";
		}
	}
	windowDef movementa {
		
		rect	320, 0, 320, 240
		matcolor  0.7, 1, 1, 0.9
		background	"guis/assets/non_interact/autopsyscan/slabshot2"

	}
	windowDef movementb {
		
		rect	320, 240, 320, -240
		matcolor  0.7, 1, 1, 0.9
		background	"guis/assets/non_interact/autopsyscan/slabshot2"

	}	


	windowDef scannerman {

		rect 		0, 0, 0, 0
		backcolor	1, 1, 1, 0 
		matcolor	0.5, 1, 1, 1 
		background	"guis/assets/mutate/1/blur1"

		onTime 0 {
		}

		onTime 1200 {
		
			transition "scannerman::rect" "290, 100, 50, 50" "360, 100, 50, 50 " "800" ;
		}
		onTime 2000 {
		
			transition "scannerman::rect" "360, 100, 50, 50 " "390, 110, 50, 50 " "300" ;
		}
		onTime 2300 {
		
