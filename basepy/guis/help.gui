#define TITLE_HIGHLIGHT_COLOR		"1 1 1 1"
#define HIGHLIGHT_TIME				"200"

#define HEADER_PROPS			textscale	0.3						\
								textalignx	5						\
								textaligny	-7						\
								shadow		1

#define TITLE_PROPS_MOVEMENT	textscale	0.33					\
								textalignx	15						\
								textaligny	-3						\
								forecolor	1, 1, 1, 1				\
								shadow		1						\
								noTime		1						\
								onTrigger {							\
									resetTime "0";					\
								}									\
								onTime 0 {							\
									transition "forecolor" MOVEMENT_FORECOLOR_STRING TITLE_HIGHLIGHT_COLOR HIGHLIGHT_TIME;	\
								}									\
								onTime 200 {						\
									transition "forecolor" TITLE_HIGHLIGHT_COLOR MOVEMENT_FORECOLOR_STRING HIGHLIGHT_TIME;	\
								}

