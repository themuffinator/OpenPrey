#include "guis/mainmenu/menucolors.guifragment"

//--------------------------------------------------------------
// Keyboard Defines
//--------------------------------------------------------------

#define MARGINX				1
#define MARGINY				1
#define KEY_WIDTH			22
#define KEY_HEIGHT			22

#define KEYBOARD_WIDTH		KEY_WIDTH*22.5
#define KEYBOARD_HEIGHT		KEY_HEIGHT*6.6
#define HALFWIDTH			KEY_WIDTH*0.5

#define TABWIDTH			KEY_WIDTH*1.5
#define CAPSLOCKWIDTH		KEY_WIDTH*1.76
#define SHIFTWIDTH			(KEY_WIDTH*2.5-MARGINX)
#define CONTROLWIDTH		KEY_WIDTH*1.5				// 2*C + 5*A + S = 15*K
#define ALTWIDTH			KEY_WIDTH*1.32
#define SPACEBARWIDTH		(KEY_WIDTH*5.5-MARGINX)

#define ENTERWIDTH			KEY_WIDTH*2.24-MARGINX
#define RIGHTSHIFTWIDTH		KEY_WIDTH*2.52

#define KEY_ARROWCOLUMN		KEY_WIDTH*15.2
#define KEY_KPADCOLUMN		KEY_WIDTH*18.4

#define KEY_ROW1			0
#define KEY_ROW2			MARGINY*5+KEY_HEIGHT
#define KEY_ROW3			MARGINY*5+KEY_HEIGHT*2
#define KEY_ROW4			MARGINY*5+KEY_HEIGHT*3
#define KEY_ROW5			MARGINY*5+KEY_HEIGHT*4
#define KEY_ROW6			MARGINY*5+KEY_HEIGHT*5

#define KEY_PROPS			backcolor		0, 0, 0, 0	\

#define KEYBOARDBG_WIDTH	(KEYBOARD_WIDTH+10)
#define KEYBOARDBG_HEIGHT	(KEYBOARD_HEIGHT+10)
#define KEYBOARDMOUSEGAP	5
#define MOUSE_WIDTH			(640-(KEYBOARDBG_WIDTH+KEYBOARDMOUSEGAP))
#define MOUSE_HEIGHT		KEYBOARDBG_HEIGHT


//--------------------------------------------------------------
// Binding Defines
//--------------------------------------------------------------
#define BIND_VMARGIN			5
#define BIND_MARGIN				32
#define TITLE_WIDTH				220
#define BIND_WIDTH				220
#define BIND_HEIGHT				20
#define HEADER_WIDTH			TITLE_WIDTH+BIND_WIDTH
#define HEADER_HEIGHT			25

#define COLUMN123_HEIGHT		20
#define COLUMN456_HEIGHT		135

#define COLUMNBG_X				(300 - ((TITLE_WIDTH+BIND_WIDTH)*3 + BIND_MARGIN*2)*0.5)
#define COLUMNBG_Y				15
#define COLUMNBG_WIDTH			(TITLE_WIDTH+BIND_WIDTH)
#define COLUMNBG_HEIGHT			240
#define COLUMNBG_COLOR			0, 0, 0, 0.5

#define MOVEMENT_FORECOLOR			0, 0.38, 0.38, 1
#define MOVEMENT_FORECOLOR_STRING	"0 0.38 0.38 1"
#define MOVEMENT_GROUPCOLOR			1, 0, 0, 1
#define WEAPONS_FORECOLOR			0.47, 0.71, 0.47, 1
#define WEAPONS_FORECOLOR_STRING	"0.47 0.71 0.47 1"
#define WEAPONS_GROUPCOLOR			0, 0.7, 0, 1
#define COMBAT_FORECOLOR			0.43, 0.43, 0.71, 1
#define COMBAT_FORECOLOR_STRING		"0.43 0.43 0.71 1"
#define COMBAT_GROUPCOLOR			0.2, 0.4, 0.9, 1
#define LOOK_FORECOLOR				0.74, 0.73, 0.52, 1
#define LOOK_FORECOLOR_STRING		"0.74 0.73 0.52 1"
#define LOOK_GROUPCOLOR				0.9, 0.9, 0.2, 1
#define SYSTEM_FORECOLOR			0.39, 0.77, 0.76, 1
