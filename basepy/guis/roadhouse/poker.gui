#define DIAMONDS	0
#define HEARTS		1
#define SPADES		2
#define CLUBS		3

windowDef desktop {
	rect		0, 0, 640, 480
	backcolor	0, 0, 0, 0
	float gameisover	0
	float incingbet		0
	float decingbet		0
	cursor 2		// Earth cursor

	onNamedEvent Update {
		// Variables just updated.  Do any maintenance here
		if ("gui::bgameover" != 0 && "desktop::gameisover" == 0) {
			set "cmd" "play console_game_gameover" ;
			set "desktop::gameisover" "1";
			set "GameOver::textscale" "0.2" ;
			resettime "GameOver" "0";
		}
	}

	onAction {
		if ("gui::bgameover") {
			set "cmd" "restart ; play console_game_insertcredit" ;
			set "desktop::gameisover" "0" ;
		}
	}

	//--------------------------------------------------------------------
	//			On/Off logic
	//--------------------------------------------------------------------
	onNamedEvent TurnOff {
		resettime "PowerOffAnim" "0";
	}
	onNamedEvent TurnOn {
		set "cmd" "reset" ;
		resettime "PowerOnAnim" "0";
	}
	
	windowDef BlackOut {
		rect		0, 0, 640, 480
		background	"guis/assets/arcade/cardscreen"
		matcolor	1, 1, 1, 1
		visible		0
	}

	windowDef PowerOffAnim {
		rect		0, 0, 0, 0
		noTime		1
		onTime 0 {
			set "desktop::noninteractive" "1" ;
			set "WholeScreen::visible" "0" ;
			set "BlackOut::visible" "1" ;
			transition "BlackOut::rect" "0 0 640 480" "320 240 0 0" "300";
		}
	}
	
	windowDef PowerOnAnim {
		rect		0, 0, 1, 1
		noTime		1
		onTime 0 {
			set "BlackOut::visible" "1" ;
			transition "BlackOut::rect" "320 240 0 0" "0 0 640 480" "300";
		}
		onTime 300 {
			set "desktop::noninteractive" "0" ;
			set "WholeScreen::visible" "1" ;
			set "BlackOut::visible" "0" ;
		}
	}

	//--------------------------------------------------------------------
	// Game screen
	//--------------------------------------------------------------------
	windowDef WholeScreen {
		rect		0, 0, 640, 480
		background	"guis/assets/arcade/cardscreen"
		matcolor	1, 1, 1, 1

		windowDef Payout {
			text		"#str_20392"
			rect		25, 385, 100, 35
			backcolor	0 ,0 ,0 ,0 
			forecolor	1 ,1 ,1 ,0.8 
			bordersize	0
			bordercolor	1 ,1 ,1 ,1 
			textscale	0.4
			textalign	1
			shadow		1
		}
		windowDef Credits {
			text		"#str_20355"
			rect		520, 385, 100, 35
			backcolor	0 ,0 ,0 ,0 
			forecolor	1 ,1 ,1 ,0.8 
			bordersize	0
			bordercolor	1 ,1 ,1 ,1 
			textscale	0.4
			textalign	1
			shadow		1
		}
		
		windowDef NumCredits {
			text		"gui::credits"
			rect		485, 410, 100, 35
			backcolor	0 ,0 ,0 ,0 
			forecolor	0.1 ,1 ,0.9 ,0.9
			bordersize	0
			bordercolor	1 ,1 ,1 ,1 
			textscale	0.45
			textalign	2
			shadow		1
		}

		windowDef Deck {
			rect		35, 125, 75, 120 
			background	"guis/assets/bj/deck.tga"
			matcolor	1 ,1 ,1 ,1 
		}
		windowDef Deck2 {
			rect		30, 130, 75, 120 
			background	"guis/assets/bj/deck.tga"
			matcolor	1 ,1 ,1 ,1 
		}

		
		windowDef PlaceBet {
			text		"#str_20356"
			rect		415, 185, 100, 35
			backcolor	0 ,0 ,0 ,0 
			forecolor	1 ,1 ,1 ,0.9
			bordersize	0
			bordercolor	1 ,1 ,1 ,1 
			textscale	0.6
			textalign	2
			visible		"gui::bcanincbet"
			shadow		1
		}

		windowDef IncButtonGfx {
			rect		537, 147, 70, 35
			background	"guis/assets/arcade/cred_button.tga"
			matcolor	0, 1, 1, 1
			visible		"gui::bcanincbet"
			noevents	1
		}
		windowDef IncButton {
			rect		520, 140, 105, 50
			visible		"gui::bcanincbet"
			notime		1
			
			onMouseEnter {
				set	"matcolor" "1 1 0 1" ; 
			} 
			onMouseExit {
				set	"matcolor" "0 1 1 1" ; 
				set "desktop::incingbet" "0" ;
			} 
			onAction {
				set "cmd" "incbet" ;
				set "desktop::incingbet" "1" ;
				set "gui::increment" "1";
				resetTime "0" ;
			} 
			onActionRelease {
				set "desktop::incingbet" "0" ;
			}
			onDeactivate {
				set "desktop::incingbet" "0" ;
			}
			onTime 300 {
				if ("desktop::incingbet") {
					set "cmd" "incbet" ;
					inc "gui::increment" "1";
					resetTime "250" ;
				}
			}
		}

		windowDef Bet {
			text		"gui::currentbet"
			rect		520, 189, 80, 30
			backcolor	0 ,0 ,0 ,0 
			forecolor	0.1 ,1 ,0.9 ,0.9
			bordersize	0
			bordercolor	1 ,1 ,1 ,1 
			textscale	0.50
			textalign	2
			visible		1
		}

		windowDef DecButtonGfx {
			rect		537, 230, 70, 35
			background	"guis/assets/arcade/cred_button2.tga"
			matcolor	0, 1, 1, 1
			visible		"gui::bcandecbet"
			noevents	1
		}
		windowDef DecButton {
			rect		520, 220, 105, 58
			visible		"gui::bcandecbet"
			notime		1
			
			onMouseEnter {
				set	"matcolor" "1 1 0 1" ; 
			} 
			onMouseExit {
				set	"matcolor" "0 1 1 1" ; 
				set "desktop::decingbet" "0" ;
			} 
			onAction {
				set "cmd" "decbet" ; 
				set "desktop::decingbet" "1" ;
				set "gui::increment" "1";
				resetTime "0" ;
			} 
			onActionRelease {
				set "desktop::decingbet" "0" ;
			}
			onDeactivate {
				set "desktop::decingbet" "0" ;
			}
			onTime 300 {
				if ("desktop::decingbet") {
					set "cmd" "decbet" ;
					inc "gui::increment" "1";
					resetTime "250" ;
				}
			}
		}


		windowDef DealButton {
			text		"#str_20357"
			rect		145, 165, 90, 50 
			background	"guis/assets/arcade/button.tga"
			matcolor	0, 1, 1, 1
			forecolor	0, 0, 0, 1
			textscale	0.45
			textalign	1
			textaligny	7
			visible		"gui::bcandeal"
			onMouseEnter {
				set	"matcolor" "1 1 0 1" ; 
				set "cmd" "play console_generic_mouseover" ;
			} 
			onMouseExit {
				set	"matcolor" "0 1 1 1" ; 
			} 
			onAction {
				set "cmd" "deal ; play console_cards_activate" ;
			} 
		}
		windowDef DrawButton {
			text		"#str_20381"
			rect		245, 165, 100, 50 
			background	"guis/assets/arcade/button.tga"
			matcolor	0, 1, 1, 1
			forecolor	0, 0, 0, 1
			textscale	0.45
			textalign	1
			textaligny	7
			visible		"gui::bcandraw"
			onMouseEnter {
				set	"matcolor" "1 1 0 1" ; 
				set "cmd" "play console_generic_mouseover" ;
			} 
			onMouseExit {
				set	"matcolor" "0.5 0.9 0.1 1.0" ; 
			} 
			onAction {
				set "cmd" "draw ; play console_cards_activate" ;
			}
		}

		// Suit background graphics don't show up:
		// NON-simple windows can't currently use background "gui::asdf"
		// using a gui:: variable for "visible" seems to force non-simple
		// Should work after merge, then get rid of temp windows showing suit

		windowDef PlayerCard1 {
			text		"gui::Player1_Mark"
			textscale	2
			textalign	1
			textaligny	5
			rect		117, 240+("gui::Player1_Marked" * 10), 75, 120 
 			forecolor	1, 0, 0, 0.5
			matcolor	1, 1, 1, 1
			background	"guis/assets/arcade/card.tga"
			visible		"gui::Player1_Visible"
			
			windowDef PC1SuitDiamonds {
				rect		0, 0, 75, 120 
				background	"guis/assets/bj/diamond.tga"
				matcolor	1, 1, 1, 1
				visible		("gui::Player1_Suit" == DIAMONDS)
			}
			windowDef PC1SuitHearts {
				rect		0, 0, 75, 120 
