			textalign	0
			shadow		1
			visible		("gui::hand" >= 0) && ("gui::creditswon" > 0)
		}

		windowDef GameOver {
			text		"#str_20367"
			rect		0, 150, 640, 180
			backcolor	0, 0, 0, 0
			forecolor	1, 0, 1, 1
			textalign	1
			textscale	0.2
			shadow		1
			visible		"gui::bgameover"
			notime		1
			onTime 0 {
				transition "textscale" "0.2" "3.2" "4000" ;
			}
			onTime 1 {
				transition "forecolor" "1 0 1 1" "1 0 0 1" "2000" ;
			}
			onTime 2000 {
				transition "forecolor" "1 0 0 1" "1 1 0 1" "2000" ;
			}
			onTime 4000 {
				transition "forecolor" "1 1 0 1" "0 1 0 1" "2000" ;
			}
			onTime 6000 {
				transition "forecolor" "0 1 0 1" "0 1 1 1" "2000" ;
			}
			onTime 8000 {
				transition "forecolor" "0 1 1 1" "0 0 1 1" "2000" ;
			}
			onTime 10000 {
				transition "forecolor" "0 0 1 1" "1 0 1 1" "2000" ;
			}
			onTime 12000 {
				resettime "1";
			}
		}

		windowDef scan1 {
			rect		0, 0, 640, 480
			backcolor	0, 0, 0, 0
			matcolor	1, 1, 1, 1
			background	"guis/assets/scanline/g_scan3"
			noevents	1
		}
		windowDef flicker {
			rect		0, 0, 640, 480
			backcolor	0, 0, 0, 0.09-powersurge2[time*0.002]
			noevents	1
		}

	
		// Damage overlays, visible when console has been damaged
		windowDef damageOverlayStatic {
			rect		0, 0, 640, 480
			matcolor	1, 1, 1, 1
			background	"guis/assets/damageOverlayStatic"
			visible		"gui::damaged"
			noevents	1
		}

		windowDef damageOverlayVHold {
			rect		0, 0, 640, 480
			matcolor	1, 1, 1, 1
			background	"guis/assets/damageOverlayVHold"
			visible		"gui::damaged"
			noevents	1
		}
		windowDef damageOverlayMask {
			rect		0, 0, 640, 480
			matcolor	1, 1, 1, 1
			background	"guis/assets/arcade/maskstatic"
			visible		"gui::damaged"
			noevents	1
		}
		
	}	// wholescreen
	
}