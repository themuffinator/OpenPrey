				textaligny	-5
			}
			windowDef PC1Lower {
				text		"gui::Player1_Card"
				rect		40, 85, 30, 30 
				forecolor	"gui::Player1_Red", 0, 0, 1
				textscale	0.5
				textaligny	-5
				textalign	2
			}
			onMouseEnter {
				transition "matcolor" "1 1 1 1" "1 0.5 0.5 1" "500" ;
				set "cmd" "play console_generic_mouseover" ;
			} 
			onMouseExit {
				transition "matcolor" "1 0.5 0.5 1" "1 1 1 1" "500" ;
			} 
			onAction {
				if ("gui::bcanmark1" != 0) {
					set "cmd" "mark1 ; play console_poker_toggle" ;
				}
			} 
		}
