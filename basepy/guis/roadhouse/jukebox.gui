		// Right to left
		windowDef Meter1 {
			rect		8*BARMETER_STEPX, 0*BARMETER_STEPY + BARMETER_HEIGHT * (1 - "gui::amplitude1"), BARMETER_WIDTH, "gui::amplitude1"*BARMETER_HEIGHT
