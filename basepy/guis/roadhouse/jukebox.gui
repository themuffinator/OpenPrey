	windowDef Selections {
		rect		SELECTIONS_X, SELECTIONS_Y, 640, 80
		backcolor	0, 0, 0, 0

		windowDef Previousbg {
			rect		200, 0, -120, 65
			matcolor	1, 1, 1, 0.4
			background	"guis/assets/jukebox/button1.tga"
			
		}
		windowDef Previous {
			rect		180, 10, 100, 50
			forecolor	1, 1, 1, 1
			onMouseEnter {
				transition "Previousbg::matcolor" "1 1 1 1" "0 1 0 1" "500" ;
			} 
			onMouseExit {
				transition "Previousbg::matcolor" "0 1 0 1" "1 1 1 0.4" "500" ;
			} 
			onAction {
				localSound "console_game_insertcredit" ;
				set "cmd" "prevtrack" ;
			}
		}
		windowDef Nextbg {
			rect		320, 0, 120, 65
			backcolor	0.2, 0.4, 0.8, 0
			matcolor	1, 1, 1, 0.4
			background	"guis/assets/jukebox/button1.tga"
			
		}
		windowDef Next{
			rect		370, 10, 100, 50
			forecolor	1, 1, 1, 1
			onMouseEnter {
				transition "Nextbg::matcolor" "1 1 1 1" "0 1 0 1" "500" ;
			} 
			onMouseExit {
				transition "Nextbg::matcolor" "0 1 0 1" "1 1 1 0.4" "500" ;
			} 
			onAction {
				localSound "console_game_insertcredit" ;
				set "cmd" "nexttrack" ;
			}
		}

		windowDef Playbg {
			rect		263, 5, 110, 55
			matcolor	1, 1, 1, 0.4
			background	"guis/assets/jukebox/button2.tga"
			
		}
		windowDef Play {
			rect		295, 10, 60, 50
			backcolor	0.2, 0.4, 0.8, 0
			forecolor	1, 1, 1, 1
			onMouseEnter {
				transition "Playbg::matcolor" "1 1 1 1" "0 1 0 1" "500" ;
			} 
			onMouseExit {
				transition "Playbg::matcolor" "0 1 0 1" "1 1 1 0.4" "500" ;
			} 
			onAction {
				localSound "console_game_insertcredit" ;
				set "cmd" "selecttrack";
			}
		}
	}

	windowDef VolumeControls {
		rect		0, 380, 640, 90

		windowDef VolumeDown {
			rect	118, 0, 80, 80
			background "guis/assets/jukebox/left_driver"
			matcolor	1, 1, 1, 1

			onAction {
				set "cmd" "volumedown";
				set "desktop::decingvol" "1" ;
				resetTime "0" ;
			}
			onMouseEnter {
				set	"matcolor" "1 1 1 1" ; 
			} 
			onMouseExit {
				set	"matcolor" "1 1 1 1" ; 
				set "desktop::decingvol" "0" ;
			} 
			onActionRelease {
				set "desktop::decingvol" "0" ;
			}
			onDeactivate {
				set "desktop::decingvol" "0" ;
			}
			onTime 300 {
				if ("desktop::decingvol") {
					set "cmd" "volumedown" ;
					resetTime "250" ;
				}
			}
		}
		
		windowDef VolumeUp {
			rect	170+275, 0, 80, 80
			background "guis/assets/jukebox/driver"
			matcolor	1, 1, 1, 1

			onAction {
				set "cmd" "volumeup";
				set "desktop::incingvol" "1" ;
				resetTime "0" ;
			}
			onMouseEnter {
				set	"driver_amp::matcolor" "1 1 1 1" ; 
			} 
			onMouseExit {
				set	"driver_amp::matcolor" "1 1 1 0" ; 
				set "desktop::incingvol" "0" ;
			} 
			onActionRelease {
				set "desktop::incingvol" "0" ;
			}
			onDeactivate {
				set "desktop::incingvol" "0" ;
			}
			onTime 300 {
				if ("desktop::incingvol") {
					set "cmd" "volumeup" ;
					resetTime "250" ;
				}
			}
		}
		windowDef Volume {
			rect		210, 32, 220 * "gui::volume", 15
			backcolor	1, 0, 0, 0.8
		}
		windowDef Volumeholder {
			rect		202, 28, 238, 25
			matcolor	1, 1, 1, 1
			background	"guis/assets/jukebox/meterholder"
		}
	}
	
}