#define BARMETER_LEFT_X		35
#define BARMETER_LEFT_Y		140
#define BARMETER_RIGHT_X	490
#define BARMETER_RIGHT_Y	140

#define BARMETER_WIDTH		25
#define BARMETER_HEIGHT		100
#define BARMETER_STEPX		12
#define BARMETER_STEPY		15

#define BARMETER_CAGEHEIGHT		235			//BARMETER_HEIGHT+BARMETER_STEPY*9
#define BARMETER_CAGEWIDTH		133			//BARMETER_WIDTH+BARMETER_STEPX*9

#define SELECTIONS_X		0
#define SELECTIONS_Y		35

#define ALBUMCOVER_X		187		//210
#define ALBUMCOVER_Y		120		//255
#define ALBUMCOVER_WIDTH	270		//180
#define ALBUMCOVER_HEIGHT	260		//160

windowDef desktop {
	rect		0, 0, 640, 480
	backcolor	0, 0, 0, 1
	float incingvol		0
	float decingvol		0
	cursor		2		// Earth cursor

	//--------------------------------------------------------------------
	//			On/Off logic
	//--------------------------------------------------------------------
	onNamedEvent TurnOff {
		resettime "PowerOffAnim" "0";
		set "cmd" "turnoff" ;
	}
	onNamedEvent TurnOn {
		resettime "PowerOnAnim" "0";
		set "cmd" "turnon" ;
	}
	onNamedEvent TurnOnRoadhouse {
		resettime "PowerOnAnimRoadhouse" "0";
		set "cmd" "turnon" ;
	}
	onNamedEvent SetNonInteractive {
		set "desktop::noninteractive" "1" ;
	}

	windowDef BlackOut {
		rect		0, 0, 640, 480
		backcolor	0, 0, 0, 1
		visible		0
	}

	windowDef PowerOffAnim {
		rect		0, 0, 0, 0
		noTime		1
		onTime 0 {
			set "desktop::noninteractive" "1" ;
			set "AlbumCovers::visible" "0" ;
			set "Selections::visible" "0" ;
			set "BarMeterL1::visible" "0" ;
			set "BarMeterL2::visible" "0" ;
			set "BarMeterR1::visible" "0" ;
			set "BarMeterR2::visible" "0" ;
			set "VolumeControls::visible" "0" ;
			transition "theBackground::rect" "15 10 613 460" "320 240 0 0" "300";
		}
	}
	
	windowDef PowerOnAnim {
		rect		0, 0, 0, 0
		noTime		1
		onTime 0 {
			transition "BlackOut::rect" "320 240 0 0" "0 0 640 480" "300";
		}
		onTime 300 {
			set "desktop::noninteractive" "0" ;
			set "AlbumCovers::visible" "1" ;
			set "Selections::visible" "1" ;
			set "BarMeterL1::visible" "1" ;
			set "BarMeterL2::visible" "1" ;
			set "BarMeterR1::visible" "1" ;
			set "BarMeterR2::visible" "1" ;
			set "VolumeControls::visible" "1" ;
			transition "theBackground::rect" "320 240 0 0" "15 10 613 460" "300";
		}
	}

	windowDef PowerOnAnimRoadhouse {
		rect		0, 0, 0, 0
		noTime		1
		onTime 0 {
			set "desktop::noninteractive" "1" ;	// Never turn interactivity back on
			transition "BlackOut::rect" "320 240 0 0" "0 0 640 480" "300";
		}
		onTime 300 {
			set "AlbumCovers::visible" "1" ;
			set "Selections::visible" "1" ;
			set "BarMeterL1::visible" "1" ;
			set "BarMeterL2::visible" "1" ;
			set "BarMeterR1::visible" "1" ;
			set "BarMeterR2::visible" "1" ;
			set "VolumeControls::visible" "1" ;
			transition "theBackground::rect" "320 240 0 0" "15 10 613 460" "300";
		}
	}

	windowDef theBackground {
		rect		15, 10, 613, 460
		matcolor	1, 1, 1, 1
		background	"guis/assets/jukebox/screen.tga"
	}


	// ------------------------------------------------------------
	// ------------------------------------------------------------
	// Left side meters
	// ------------------------------------------------------------
	// ------------------------------------------------------------

