
#define ROLLOVER_FORECOLOR		"0.65 1 0.2 0.4"

// Keycode must be entered to proceed
//

windowDef Desktop {
	rect			0, 0, 640, 480
	forecolor		1, 1, 1, 1
	backcolor		0, 0, 0, 0
	float done		0				// Whether puzzle has been solved
	float played	0				// Whether failure sound has played once this entry

	onEvent {
		if ("done" == 0) {
			if ("gui::keypad" != "" && "gui::keypad" == "gui::gui_parm_keycode") {
				resetTime "acceptSequence" "0" ;
				
				// Turn invalid off if it was playing
				resetTime "invalidSequence" "1500" ;
				set "invalidSequence::notime" "1" ;
				set "invalid_text::visible" "0" ;
				set "invalid::visible" "0" ;
				
				set "cmd" "activate ; play console_keypad_victory" ;
				set "done" "1";
			}
			else {
				if ("gui::atmax" == 1) {
					if ("played" == 0) {
						resetTime "invalidSequence" "0" ;
						set "cmd" "play console_keypad_failure" ;
						set "played" "1";
					}
				}
			}
		}
	}
	
// -------------------------------------------------------------------------------
// Animation control definitions
// -------------------------------------------------------------------------------

	windowDef acceptSequence {
		rect		0, 0, 0, 0
		visible		1
		notime		1

		onTime 10 {
			transition "accept::matcolor" "0.4 0.9 1 0" "0.4 0.9 1 1" "500" ;	
		}
		onTime 500 {
			set "accept_text::visible" "1";
		}
		onTime 1200 {
			resetTime "acceptSequence" "0" ;
		}	
	}

	windowDef invalidSequence {
		rect		0, 0, 0, 0
		visible		1
		notime		1

		onTime 10 {
			transition "invalid::matcolor" "1 0.1 0 0" "1 0.1 0 1" "500" ;	
		}
		onTime 500 {
			set "invalid_text::visible" "1";
		}
		onTime 1200 {
			resetTime "invalidSequence" "0" ;
		}	
	}






