	windowDef zero {
		rect		30, 270, 130, 80
		forecolor	1, 1, 1, 0.6
		backcolor	0, 0, 0, 0
		text		"O"
		textscale	1.4
		textalign	1
		font		"fonts/alien"

		onMouseEnter {
			transition "backzero::matcolor" "1 1 1 0.5" "1 1 1 1" "70" ;
			transition "forecolor" "1 1 1 0.6" ROLLOVER_FORECOLOR "70" ;
		}
		onMouseExit {
			transition "backzero::matcolor" "1 1 1 1" "1 1 1 0.5" "70" ;
			transition "forecolor" ROLLOVER_FORECOLOR "1 1 1 0.6" "70" ;
		}
		onAction {
			if ("Desktop::done" == 0) {
				set "cmd" "play guisounds_menu_keyclick";
				if ("gui::atmax" == 1) {
					set "cmd" "clear ; keypad_0";
					set "Desktop::played" "0";
				//	set "Output::backcolor" "0 0 0 0";
				}
				else {
					set "cmd" "keypad_0";
				}
			}
		} 
	}
