	//=======================================
	// Help
	//=======================================

	windowDef Help_Mode {
	}

	windowDef Help_Options_Open {
		noTime		1
		
		onTime 0 {
			transition "Help_Options::rect" "0 90 75 15" "0 0 640 480" "400" ;
			set "Help_Options::visible" "1" ;
		}
		onTime 400 {
			set "Help_OptionsText::visible" "1" ;
		}
	}
	windowDef Help_Options_Close {
		noTime		1
		
		onTime 0 {
			transition "Help_Options::rect" "0 0 640 480" "0 90 75 15" "400";
			set "Help_OptionsText::visible" "0" ;
		}
		onTime 400 {
			set "Help_Options::visible" "0" ;
		}
		
	}
	windowDef Help_Options {
		rect		0, 90, 75, 15
		backcolor	0, 0, 0, 0.5
		textscale	0.4
		visible		0
		noTime		1

		onAction {
			resetTime "Help_Options_Close" "0";
		}
		
		windowDef ho_key {
			// show colors and what they mean
		}
		
		windowDef Help_OptionsText {
			rect		80, 100, 550, 280
			backcolor	0, 0, 0, 0
			forecolor	1, 1, 1, 1
			text		"Help - Options\nDraw Entities: Draws a crosshair at each entity defined by filters\nClass Collapse:  Collapses the entities into their respective classes\nPointer:             Allows you to point at the entity you want to select"
			textscale	0.4
			nowrap		1
			visible		0
		}
	}
	
	windowDef Help_Filters {
	}
