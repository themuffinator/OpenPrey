// debugger.gui

/*
	TODO:
	Help for all tools
	Color Keys for help
	Make sure filters are working correctly
*/


#define DEBUGMODE_NONE		0
#define DEBUGMODE_STATS		1
#define DEBUGMODE_SPAWNARGS	2
#define DEBUGMODE_GAMEINFO1	3
#define DEBUGMODE_GAMEINFO2	4
#define DEBUGMODE_GAMEINFO3	5


windowDef Desktop {
	rect			0, 0, 640, 480
	backcolor		0, 0, 0, 0
	forecolor		1, 1, 1, 1
	vscroll			1
	hscroll			1
	notime			1
	nowrap			1
	menugui			1

	//=======================================
	// Mode
	//=======================================
	windowDef Tool_ModeFrame {
		rect		0, 40, 75, 50
		backcolor	0, 0, 0, 0
		forecolor	1, 1, 1, 1
		bordercolor	0.4, 0.6, 0.8, 0.5
		bordersize	1
		text		"MODE:"
		textaligny	-5
		textscale	0.3

		onMouseEnter {
			set "Tool_ModeFrame::backcolor" "1 1 1 0.5";
		}
		onMouseExit {
			set "Tool_ModeFrame::backcolor" "0 0 0 0";
		}
		onAction {
			set "cmd" "guicmd_cyclemode" ;
		}

		windowDef Tool_Mode {
			rect			5, 12, 65, 25
			backcolor		0, 0, 0, 0
			forecolor		1, 1, 0, 1
			textscale		0.4
			text			"Stats"
			onNamedEvent SetMode {
				if ("gui::mode" == DEBUGMODE_NONE) {
					set "Tool_Mode::text" "None";
				}
				if ("gui::mode" == DEBUGMODE_STATS) {
					set "Tool_Mode::text" "Stats";
				}
				if ("gui::mode" == DEBUGMODE_SPAWNARGS) {
					set "Tool_Mode::text" "Args";
				}
				if ("gui::mode" == DEBUGMODE_GAMEINFO1) {
					set "Tool_Mode::text" "Game1";
				}
				if ("gui::mode" == DEBUGMODE_GAMEINFO2) {
					set "Tool_Mode::text" "Game2";
				}
				if ("gui::mode" == DEBUGMODE_GAMEINFO3) {
					set "Tool_Mode::text" "Game3";
				}
			}
		}
	}

	//=======================================
	// Options
	//=======================================
	windowDef OptionFrame {
		rect		0, 90, 75, 80
		backcolor	0, 0, 0, 0
		forecolor	1, 1, 1, 1
		bordercolor	0.4, 0.6, 0.8, 0.5
		bordersize	1

		windowDef Option_Title {
			rect		0, 0, 75, 15
			backcolor	0, 0, 0, 0
			forecolor	1, 1, 1, 1
			text		"Options:"
			textaligny	-5
			textscale	0.3
			onMouseEnter {
				set "Option_Title::forecolor" "1 1 0.6 1";
			}
			onMouseExit {
				set "Option_Title::forecolor" "1 1 1 1";
			}
			onAction {
				resetTime "Help_Options_Open" "0";
			}
		}
		
		windowDef Option_DrawEntities {
			rect		0, 20, 75, 15
			forecolor	0.5, 0.5, 0.5, 1
			text		"Draw Entities"
			textscale	0.3
			textaligny	-5
			onMouseEnter {
				set "Option_DrawEntities::backcolor" "1 1 1 0.5";
			}
			onMouseExit {
				set "Option_DrawEntities::backcolor" "0 0 0 0.1";
			}
			onAction {
				set "cmd" "guicmd_drawentities" ;
			}
			onNamedEvent SetDrawEntities {
				if ("gui::drawEntities" == 1) {
					set "Option_DrawEntities::forecolor" "1 1 0 1" ;
				}
				else {
					set "Option_DrawEntities::forecolor" "0.5 0.5 0.5 1" ;
				}
			}
		}

		windowDef Option_ClassCollapse {
			rect		0, 35, 75, 15
			forecolor	1, 1, 0, 1
			text		"Class Collapse"
			textscale	0.3
			textaligny	-5
			onMouseEnter {
				set "Option_ClassCollapse::backcolor" "1 1 1 0.5";
			}
			onMouseExit {
				set "Option_ClassCollapse::backcolor" "0 0 0 0.1";
			}
			onAction {
				set "cmd" "guicmd_classcollapse" ;
			}
			onNamedEvent SetClassCollapse {
				if ("gui::classcollapse" == 1) {
					set "Option_ClassCollapse::forecolor" "1 1 0 1" ;
				}
				else {
					set "Option_ClassCollapse::forecolor" "0.5 0.5 0.5 1" ;
				}
			}
		}

		windowDef Option_Pointer {
			rect		0, 50, 75, 15
			forecolor	1, 1, 0, 1
			text		"Pointer"
			textscale	0.3
			textaligny	-5
			onMouseEnter {
				set "Option_Pointer::backcolor" "1 1 1 0.5";
			}
			onMouseExit {
				set "Option_Pointer::backcolor" "0 0 0 0.1";
			}
			onAction {
				set "cmd" "guicmd_pointer" ;
			}
			onNamedEvent SetPointer {
				if ("gui::pointer" == 1) {
					set "Option_Pointer::forecolor" "1 1 0 1" ;
				}
				else {
					set "Option_Pointer::forecolor" "0.5 0.5 0.5 1" ;
				}
			}
		}
	}

	//=======================================
	// Filters
	//=======================================
	windowDef FilterFrame {
		rect		0, 170, 75, 230
		backcolor	0, 0, 0, 0
		forecolor	1, 1, 1, 1
		bordercolor	0.4, 0.6, 0.8, 0.5
		bordersize	1
		text		"Filters:"
		textaligny	-5
		textscale	0.3

		windowDef FilterClass {
			rect 		0, 20, 75, 15
			backcolor 	0, 0, 0, 0
			forecolor 	1, 1, 1, 1
			text		"Class"	//TODO: Use gui::variable to put actual classname in here
			textaligny	-5
			textscale 	0.3
			onMouseEnter {
				set "FilterClass::backcolor" "1 1 1 0.5";
			}
			onMouseExit {
				set "FilterClass::backcolor" "0 0 0 0";
			}
			onAction {
				set "cmd" "guicmd_filter1" ;
			}
			onNamedEvent SetFilter {
				if ("gui::filter1" == 0) {		// Ignore
					set "FilterClass::forecolor" "1 1 1 1" ;
				}
				else {							// Included or Excluded
					set "FilterClass::forecolor" "1 1 0 1" ;
				}
			}
			windowDef FilterClass_Include {		// Green outline
				rect		0, 0, 75, 15
				backcolor	0, 0, 0, 0
				bordercolor	0, 1, 0, 1
				bordersize	1
				visible		("gui::filter1" == 1)
			}
			windowDef FilterClass_Exclude {		// Red strikethrough
				rect		0, 7, 75, 2
				backcolor	1, 0, 0, 1
				bordercolor	1, 0, 0, 1
				bordersize	1
				visible		("gui::filter1" == 2)
			}
		}

