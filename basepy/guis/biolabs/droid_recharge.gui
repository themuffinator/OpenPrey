	windowDef meter1 {
		rect        24, 454, 32, 0
		backcolor    0, 0, 0, 0
		matcolor    1, 1, 1, 1
		background    "guis/assets/droid_recharge/strip"
		visible        1
		onTime 0 {
			transition "meter1::rect" "24, 453, 0, 11" "24, 453, 116, 11" "3000" ;
			transition "meter1::matcolor"	"1 1 1 0"   "1 1 1 1" "3000" ;
			set "meter1::visible" "1" ;
		}
		onTime 4500 {
//			transition "meter1::rect" "24, 453, 116, 11" "24, 453, 0, 11" "0" ;
			transition "meter1::matcolor"	"1 1 1 1"   "1 1 1 0" "500" ;
//			set "meter1::visible" "0" ;
		}
		onTime 5000 {
			resettime "0";
		}
	} 

