	windowDef DroidWindow {
		rect		28, 160, 273, 274
		background	"guis/assets/droid_recharge/outerbody1"
		matcolor	1, 1, 1, jitter1[time*0.0005]
		float clipperY 0
		
		onTime 0 {
			transition "clipperY" "0" "1" "3000";
		}
		onTime 4500 {
			transition "clipperY" "1" "0" "200";
		}
		onTime 5000 {
			resetTime "0";
		}

		windowDef DroidClipper {
			rect		0, 274 * (1 - "DroidWindow::clipperY"), 273, 274
			
			windowDef DroidFill {
				rect		273, 274 * "DroidWindow::clipperY", 273, 274
				background	"guis/assets/droid_recharge/innerbody1"
				invertrect	1
			}
		}
	}
	windowDef DroidWindow2 {
		rect		350, 160, 265, 274
		background	"guis/assets/droid_recharge/outerbody2"
		float clipperY 0
		
		onTime 0 {
			transition "clipperY" "0" "1" "3000";
		}
		onTime 4500 {
			transition "clipperY" "1" "0" "200";
		}
		onTime 5000 {
			resetTime "0";
		}

		windowDef DroidClipper2 {
			rect		0, 274 * (1 - "DroidWindow2::clipperY"), 265, 274
			
			windowDef DroidFill2 {
				rect		265, 274 * "DroidWindow2::clipperY", 265, 274
				background	"guis/assets/droid_recharge/innerbody2"
				invertrect	1
			}
		}
	}

