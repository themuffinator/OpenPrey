	windowDef scanner6 {


		backcolor	1, 1, 1, 0 
		forecolor	1, 1, 1, 1 
		text		"6 7 73848 738677  217838 8 23 4211288 83843 24758873  87323 612 22234  211288838 4873 8"
		font		"fonts/alien"
		textscale	0.4
		visible		1
		notranslation	1

		onTime 0 {
		}

		onTime 10 {
		
			transition "scanner6::forecolor" "1, 0.3, 0.1, 0.0" "1, 0.3, 0.1, 0.5" "1800" ;
			transition "scanner6::rect" "60, 224, 500, 40 " "-80, 224, 500, 40 " "7950" ;
			set "scanner6::visible" "1"
		}
		onTime 6400 {
			transition "scanner6::forecolor" "1, 0.4, 0.1, 0.5" "1, 0.4, 0.1, 0" "1400" ;

		}
		onTime 8000 {
			resetTime "0";
			set "scanner3::visible" "0"
		}
	}
