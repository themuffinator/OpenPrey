	windowDef coast {
		rect		300, 75, 300, 320
		background	"guis/assets/non_interact/earthmoonscan/westcoast"
		matcolor	1, 1, 1, 1
		float clipperY 0
		
		onTime 3000 {
			transition "clipperY" "0" "1" "2200";
			transition "coast::matcolor" "1, 1, 1, 1" "1, 0.1, 0.0, 0.4" "2200" ;
		}
		onTime 6500 {
			transition "clipperY" "1" "0" "1000";
			transition "coast::matcolor" "1, 0.1, 0.0, 0.4" "1, 1, 1, 1" "1000" ;
		}
		onTime 8000 {
			resetTime "0";
		}

		windowDef coastClipper {
			rect		0, 320 * (1 - "coast::clipperY"), 300, 320
			
			windowDef DroidFill {
				rect		300, 320 * "coast::clipperY", 300, 320
				background	"guis/assets/non_interact/earthmoonscan/westcoast2"
				matcolor	1, 1, 1, 0.7
				invertrect	1
			}
		}
	}



	windowDef scanner5 {

		rect 		0, 0, 0, 0
		backcolor	1, 1, 1, 0 
		forecolor	1, 1, 1, 1 
		background	"guis/assets/mutate/1/blur1"

		onTime 0 {
		}

		onTime 3000 {
		
			transition "scanner5::matcolor" "1, 0.1, 0.1, 0.0" "1, 0.8, 0.4, 0.6" "100" ;
			transition "scanner5::rect" "280, 386, 340, 15" "280, 69, 340, 15 " "2200" ;
		}
		onTime 6500 {
			transition "scanner5::rect" "280, 69, 340, 15" "280, 386, 340, 15 " "1000" ;		
		}
		onTime 7700 {
			transition "scanner5::matcolor" "1, 0.8, 0.4, 0.6" "1, 0.8, 0.5, 0" "200" ;

		}
		onTime 8000 {
			resetTime "0";
		}
	}



