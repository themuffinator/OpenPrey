    if ( cycTotal < 1 ) {
    	cycTotal = 1;//run at least once and prevent dividing by 0
    }
    
    //get a value for the sys.wait
    cycInc = 1 / cycPerSec;
    
    //destination colors - starting colors = difference values
    //difference values / cycTotal = color adjustment incs
    cInc = (fadeDeg2 - fadeDeg1) / cycTotal;
    
    //for loop...fade
//	sys.println( "light entity faded = " + ent.getName() );//debug
    for ( i = 1; i <= cycTotal; i += 1 ) {
    	fadeDeg1 += cInc;
		//SOUNDPARM_MERGE
       	//ent.setSoundParm( prm, fadeDeg1 );
//     	sys.println( "sound parm" + prm + " for " + ent.getName() + " should be = " + fadeDeg1 );//debug
       	sys.wait( cycInc );
    }
	//SOUNDPARM_MERGE
    //ent.setSoundParm( prm, fadeDeg2 );//snap it the last little bit
//	sys.println( "final sound parm value for " + ent.getName() + " should be = " + fadeDeg2 );//debug
}

//============================================================================
//FadeAll_Off( entity eTarget )
//
//Desciption: companion function that auto waits and then sets targets to an of state.  usefull for retriggered FadeAll's
//============================================================================
void FadeAll_Off( entity eTarget, float fFadeTime ) {
//	eTarget.setKey( "isOff", TRUE );
	sys.wait( fFadeTime );
	sys.trigger( eTarget );//hides or turns off entities
}

//============================================================================
//FadeAll( entity eSelf)
//
//Desciption: target and info null that targets multiple lights, func_statics, etc.  By default the entities will fade from
//	their current color to the '_color' of the relay or to 0 0 0 if no color is set.  If start_off is set on a light it
//	will fade from 0 0 0 to its set color by default.  This function, with no keys, can target multiple lights, fade them
//	all simultaneously with different fade times, and trigger on those that are off.  Its best use is to accomplish 
//	complex fades with few entities while avoiding the need to individually name and track each one in script.  Also,
//	colors can be set and updated on the maps by the mappers without disturbing the fx system. note: also fully functional 
//	with func_emitters.
//Additional uses to document: cross fade toggle setup, triggering unneeded entities off
//============================================================================
void FadeAll( entity eSelf) {
	entity eList, eTarget;
	float fNumTargs, n, fGlobalFadeTime, fFadeTime, fFadeThreadNum;
	vector vSourceVec, vDestVec;
	
	eList 		= sys.getEntity( eSelf.getKey( "target" ) );
	fNumTargs 	= eList.numTargets();
	
	if ( fGlobalFadeTime = eSelf.getFloatKey( "fadeTime" ) > 0 ) {
		fGlobalFadeTime = eSelf.getFloatKey( "fadeTime" );
	}
	else {
		fGlobalFadeTime = 1;
	}
	
	for ( n = 0; n < fNumTargs; n++ ) {
		eTarget = GetTargetEntity( eList, n);
//		PL( "Target receiving light mod = " + eTarget.getName() );
		if ( fFadeTime = eTarget.getFloatKey( "fadeTime" ) > 0 ) {
			fFadeTime = eTarget.getFloatKey( "fadeTime" );
		}
		else {
			fFadeTime = fGlobalFadeTime;
		}
		if ( ( eTarget.getIntKey( "start_off" ) == TRUE ) || 
			 ( eTarget.getIntKey( "hide" ) == TRUE ) || 
			 ( eTarget.getIntKey( "isOff" ) == TRUE ) ) {//will auto fade in lights, func_statics and particle systems
			if ( eSelf.getKey( "_color" ) == "" ) {//test and change to vector 0 0 0 check FIX
				vSourceVec	= '0 0 0';//default to fading off
				sys.trigger( eTarget );//do not trigger those entities that have an off color other than black
			}
			else {//set to custom color
				vSourceVec	= eSelf.getVectorKey( "_color" );//set to '0 0 0' to avoid triggering
			}
//			vSourceVec 	= '0 0 0';
			vDestVec	= eTarget.getVectorKey( "_color" );
			eTarget.setColor( vSourceVec_x, vSourceVec_y, vSourceVec_z );
			eTarget.setKey( "start_off", FALSE );
			eTarget.setKey( "hide", FALSE );
			eTarget.setKey( "isOff", FALSE );
		}
		else {
			vSourceVec 	= eTarget.getVectorKey( "_color" );//will fade out or cross fade all entities
			if ( eSelf.getKey( "_color" ) == "" ) {
				vDestVec	= '0 0 0';//default to fading off
			}
			else {//set to custom color
				vDestVec	= eSelf.getVectorKey( "_color" );//'0.5 1 0.75';
			}
			eTarget.setKey( "isOff", TRUE );
			if ( ( eTarget.getIntKey( "triggerOff" ) == TRUE ) || ( eSelf.getIntKey( "triggerOff" ) == TRUE ) ) {//set this on systems or entities that you want to toggle back on.
				thread FadeAll_Off( eTarget, fFadeTime );
			}
		}

		if ( eTarget.getKey( "classname" ) == "light" ) {
			fFadeThreadNum = thread Light_FadeColor( eTarget, fFadeTime, vSourceVec, vDestVec, 24 );
		}
		else {
			fFadeThreadNum = thread Parm_FadeColorLocal( eTarget, fFadeTime, vSourceVec, vDestVec, 24 );
		}
		eTarget.setKey( "fadeThreadNum", fFadeThreadNum );
//		PL( eTarget.getName() + " has stored thread # : " + fFadeThreadNum );//thread nums used to terminate fade threads early in other scripts
	}
}
//============================================================================
//FadeAll_Pulse( entity eSelf)
//
//fade pulses between states until set to isRunning;0
//============================================================================
void FadeAll_Pulse( entity eSelf) {
	float fFadeTime, fOnTime, fOffTime;
	
	if ( eSelf.getIntKey( "isBusy" ) == FALSE ) {
		eSelf.setKey( "isBusy", TRUE );//internal; stops the function from running multiple times
		eSelf.setKey( "isRunning", TRUE );//override externally to stop function
		fFadeTime = eSelf.getFloatKey( "fadeTime" );
		if ( fFadeTime <= 0 ) {
			fFadeTime = 2;
		}
		fOnTime = eSelf.getFloatKey( "onTime" );
		fOffTime = eSelf.getFloatKey( "offTime" );
		while ( eSelf.getIntKey( "isRunning" ) == TRUE ) {
			if ( eSelf.getKey( "onTarget" ) != "" ) {
				sys.trigger( sys.getEntity( eSelf.getKey( "onTarget" ) ) );//sync up events, such as sound, to the light pulse
			}
			FadeAll( eSelf );
			sys.wait( fFadeTime + fOnTime );//= to global fade time
			if ( eSelf.getKey( "offTarget" ) != "" ) {
				sys.trigger( sys.getEntity( eSelf.getKey( "offTarget" ) ) );
			}
			FadeAll( eSelf );
			sys.wait( fFadeTime + fOffTime );
		}
		eSelf.setKey( "isBusy", FALSE );
	}
}

//============================================================================
//FadeAll_PulseOff( entity eSelf)
//
//simple unCallRef companion
//============================================================================
void FadeAll_PulseOff( entity eSelf) {
	eSelf.setKey( "isRunning", FALSE );
}
