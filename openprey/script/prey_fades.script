//============================================================================
//Parm_FadeColorGlobal ( float tym, vector fadeDeg1, vector fadeDeg2, float cycPerSec)
//
//Fade in, out, and between global color parms:  
//tym 		= total time the fade takes. 					0.0 to 100.0
//fadeDeg1  = rgb starting position							0 - 1 vectors
//fadeDeg2 	= rgb ending position							0 - 1 vectors
//cycPerSec = number of changes to the parms per second		1 - 60
//============================================================================
void Parm_FadeColorGlobal ( float tym, vector fadeDeg1, vector fadeDeg2, float cycPerSec) {
	float i;//integer fed into the lights rgb
	float cycTotal;//number of cycles that the for loop runs.  preset since it has a possibility of not being declared
	float cycInc;//cycPerSec turned to a decimal value.
	vector cInc;//color adjustment increments
	
	cycTotal = 1;
	cycInc = 1;

	//color input clamps
	fadeDeg1 = VectorClamp_0ToInfinity ( fadeDeg1 );
	fadeDeg2 = VectorClamp_0ToInfinity ( fadeDeg2 );
	
    //tym clamps
    if (tym < 0.0) {
        tym = 0.0;
    }
    else if (tym > 100.0) {
        tym = 100.0;
    }
    //cycPerSec clamps
    if ( cycPerSec > 60 ) {
    	cycPerSec = 60;
    }
    if ( cycPerSec <= 0 ) {
    	cycPerSec = 0.01;
    }
    //total cycles for the loop to run based on total time and cycPerSec
    cycTotal = tym * cycPerSec;
    if ( cycTotal < 1 ) {
    	cycTotal = 1;//run at least once and prevent dividing by 0
    }
    
    //get a value for the sys.wait
    cycInc = 1 / cycPerSec;
    
    //destination colors - starting colors = difference values
    //difference values / cycTotal = color adjustment incs
    cInc_x = (fadeDeg2_x - fadeDeg1_x) / cycTotal;
    cInc_y = (fadeDeg2_y - fadeDeg1_y) / cycTotal;
    cInc_z = (fadeDeg2_z - fadeDeg1_z) / cycTotal;    

	//for loop...fade
//	sys.println( "light entity faded = " + ent.getName() );//debug
    for ( i = 1; i <= cycTotal; i += 1 ) {
    	fadeDeg1_x += cInc_x;
    	fadeDeg1_y += cInc_y;
    	fadeDeg1_z += cInc_z;
    	sys.setShaderParm( 0, fadeDeg1_x );
    	sys.setShaderParm( 1, fadeDeg1_y );
    	sys.setShaderParm( 2, fadeDeg1_z );
    	sys.wait( cycInc );
    }
    sys.setShaderParm( 0, fadeDeg2_x );//snap it the last little bit
    sys.setShaderParm( 1, fadeDeg2_y );
    sys.setShaderParm( 2, fadeDeg2_z );
//  sys.println( "final light color for " + ent.getName() + " should be = " + fadeDeg2_x +" "+ fadeDeg2_y +" "+ fadeDeg2_z );//debug
}

