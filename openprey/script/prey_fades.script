	float cycTotal;//number of cycles that the for loop runs.  preset since it has a possibility of not being declared
	float cycInc;//cycPerSec turned to a decimal value.
	vector cInc;//color adjustment increments
	
	cycTotal = 1;
	cycInc = 1;

    //tym clamps
    if (tym < 0.0) {
        tym = 0.0;
    }
    else if (tym > 100.0) {
        tym = 100.0;
    }
    //cycPerSec clamps
    if ( cycPerSec > 60 ) {
    	cycPerSec = 60;
    }
    if ( cycPerSec <= 0 ) {
    	cycPerSec = 0.01;
    }
    //total cycles for the loop to run based on total time and cycPerSec
    cycTotal = tym * cycPerSec;
    if ( cycTotal < 1 ) {
    	cycTotal = 1;//run at least once and prevent dividing by 0
    }
    
    //get a value for the sys.wait
    cycInc = 1 / cycPerSec;
    
    //destination colors - starting colors = difference values
    //difference values / cycTotal = color adjustment incs
    cInc_x = (fadeDeg2_x - fadeDeg1_x) / cycTotal;
    cInc_y = (fadeDeg2_y - fadeDeg1_y) / cycTotal;
    cInc_z = (fadeDeg2_z - fadeDeg1_z) / cycTotal;    

	//for loop...fade
//	sys.println( "light entity faded = " + ent.getName() );//debug
    for ( i = 1; i <= cycTotal; i += 1 ) {
    	fadeDeg1_x += cInc_x;
    	fadeDeg1_y += cInc_y;
    	fadeDeg1_z += cInc_z;
    	ent.setRadiusXYZ( fadeDeg1_x, fadeDeg1_y, fadeDeg1_z );
    	sys.wait( cycInc );
    }
    ent.setRadiusXYZ( fadeDeg2_x, fadeDeg2_y, fadeDeg2_z );//snap it the last little bit
//    sys.println( "final light radius for " + ent.getName() + " should be = " + fadeDeg2_x +" "+ fadeDeg2_y +" "+ fadeDeg2_z );//debug
}

//============================================================================
//Parm_FadeGlobal ( float tym, vector fadeDeg1, vector fadeDeg2, float cycPerSec )
//
//Fade in, out, and between a single global parm:
//prm 		= parm to fade.									0-7
//tym 		= total time the fade takes. 					0.0 to 100.0
//fadeDeg1  = parm starting position						0 - 1 vectors
//fadeDeg2 	= parm ending position							0 - 1 vectors
//cycPerSec = number of changes to the parm per second		1 - 60
//============================================================================
void Parm_FadeGlobal ( float prm, float tym, float fadeDeg1, float fadeDeg2, float cycPerSec ) {
	float i;//integer fed into the lights rgb
	float cycTotal;//number of cycles that the for loop runs.  preset since it has a possibility of not being declared
	float cycInc;//cycPerSec turned to a decimal value.
	float cInc;//color adjustment increments
	
	cycTotal = 1;
	cycInc = 1;

	//parm input clamps
	if (prm < 0.0) {
        prm = 0.0;
    }
    else if (prm > 7.0) {
        prm = 7.0;
    }
    prm = floor( prm );
    //tym clamps
    if (tym < 0.0) {
        tym = 0.0;
    }
    else if (tym > 100.0) {
        tym = 100.0;
    }
    //color input clamps
    if ( prm > 0 && prm < 4 ) {//if the parm is part of the rgba, clamp its value between 0-1
		fadeDeg1 = FloatClamp_0To1 ( fadeDeg1 );
		fadeDeg2 = FloatClamp_0To1 ( fadeDeg2 );
	}
    //cycPerSec clamps
    if ( cycPerSec > 60 ) {
    	cycPerSec = 60;
    }
    if ( cycPerSec <= 0 ) {
    	cycPerSec = 0.01;
    }
    
    //total cycles for the loop to run based on total time and cycPerSec
    cycTotal = tym * cycPerSec;
    if ( cycTotal < 1 ) {
    	cycTotal = 1;//run at least once and prevent dividing by 0
    }
    
    //get a value for the sys.wait
    cycInc = 1 / cycPerSec;
    
    //destination colors - starting colors = difference values
    //difference values / cycTotal = color adjustment incs
    cInc = (fadeDeg2 - fadeDeg1) / cycTotal;
    
    //for loop...fade
    for ( i = 1; i <= cycTotal; i += 1 ) {
    	fadeDeg1 += cInc;
       	sys.setShaderParm( prm, fadeDeg1 );
//     	sys.println( "parm setting for parm" + prm + " should be = " + fadeDeg1 );//debug
       	sys.wait( cycInc );
    }
    sys.setShaderParm( prm, fadeDeg2 );//snap it the last little bit
//	sys.println( "final parm setting for parm " + prm + " should be = " + fadeDeg2 );//debug
}

