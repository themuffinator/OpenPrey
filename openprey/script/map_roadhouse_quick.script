	//Handles the air particles and sound for flushing so the handle can be independent
	void BathAutoDryerCycleAir( entity knob, entity sound, entity emitter ) {
		if ( knob.getFloatKey( "isDrying" ) == 0 ) {
			knob.setKey( "isDrying", 1 );
			
			sound.On();
			sys.trigger( emitter );
			
			sys.wait( 8.5 );
			
			sys.trigger( emitter );
			
			knob.setKey( "isDrying", 0 );
		}
	}
	
	//Cycles the hand dryer
	void BathAutoDryerCycle( entity knob, entity sound, entity pushOnSound, entity emitter ) {		
		if ( knob.getFloatKey( "isRunning" ) == 0 ) {
			knob.setKey( "isRunning", 1 );
			
			pushOnSound.On();
			
			knob.move( SOUTH, 0.5 );
			sys.waitFor( knob );
			
			thread BathAutoDryerCycleAir( knob, sound, emitter );
			
			knob.move( NORTH, 0.5 );
			sys.waitFor( knob );
					
			knob.setKey( "isRunning", 0 );
		}
	}
	
	void BathMAutoDryerCycle() {
		BathAutoDryerCycle( $rhBathMAutoDryerKnob, $rhBathMAutoDryerSound, $rhBathMAutoDryerPushOnSound, $rhBathMAutoDryerEmitter );
	}
	
