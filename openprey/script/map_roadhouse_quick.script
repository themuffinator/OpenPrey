		TimeTweak( $rhShipProjLightMiddleSource2, 0.75, 0.5, 1.5 );
		
		$rhShipProjLightMiddleSource1.setColor( 0, 0, 0 );
		$rhShipProjLightMiddleSource2.setColor( 0, 0, 0 );
		
		//start ship lights off
		float i;
		entity currentEnt;
		
		for ( i = 1; i <= 16; i++ ) {
			if ( currentEnt = sys.getEntity( "rhShipLight" + i ) ) {
				currentEnt.Off();
			}
			
			if ( currentEnt = sys.getEntity( "rhShipLight" + i + "Source" ) ) {
				currentEnt.setColor( 0, 0, 0 );
			}
			
			if ( currentEnt = sys.getEntity( "rhShipLight" + i + "Flare" ) ) {
				currentEnt.setColor( 0, 0, 0 );
			}
		}
		
		$rhShipGreenLight1.Off();
		$rhShipGreenLight2.Off();
		$rhShipGreenLight3.Off();
		$rhShipGreenLight4.Off();
	}
	
