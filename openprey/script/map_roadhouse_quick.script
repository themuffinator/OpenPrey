	float g_CasinoMode = 0; //Games only, no dialog, can't progress
			
	//returns a free light cone "ship guide"
	entity GetShipGuide() {
		float i;
		entity currentEnt;
		
		for ( i = 1; i <= 10; i++ ) {
			if ( currentEnt = sys.getEntity( "rhShipGuideCone" + i ) ) {
				if ( !currentEnt.getFloatKey( "busy" ) ) {
					return currentEnt;
				}
			}
		}
		
		return $null_entity;
	}
	
	//Additional light cone that tracks objects as they're picked up
	void ShipGuideTrack( entity target, float isNPC, vector offset ) {
		entity lightSource = GetShipGuide();
		
		if ( lightSource == $null_entity ) {
			return;
		}
		
		vector lightSourceColor = lightSource.getVectorKey( "_color" );
		float targetID = sys.getEntitySpawnId( target );
		
		if ( target == $player1 ) {
			lightSourceColor *= 4;
		}
		
		lightSource.setKey( "busy", 1 );
		
		lightSource.time( sys.getFrameTime() );
		thread fadeInEnt( lightSource, lightSourceColor, 2 );
		lightSource.show();
		
		vector vecToTarget,
			   targetAngle,
			   targetOrigin,
			   sourceOrigin = lightSource.getVectorKey( "origin" );
		
		while ( CheckSpawnId( target, targetID ) ) {
			if ( !isNPC ) {
				targetOrigin = target.getWorldOrigin() + offset;
			} else {
				targetOrigin = target.getJointPos( target.getJointHandle( "waist" ) ) + offset;
			}
			vecToTarget = VecSubtract( targetOrigin, sourceOrigin );
			targetAngle = sys.VecToAngles( vecToTarget );
			targetAngle_x -= 90;
			targetAngle = anglemod360( targetAngle );
			
			lightSource.rotateTo_world( targetAngle );
			sys.waitFrame();
		}
		
		fadeOutEnt( lightSource, lightSourceColor, 1 );
		lightSource.hide();
		lightSource.setKey( "busy", 0 );
	}
	
	//Stops sound and removes entity after X seconds
	void DelayedRemove( entity entityToRemove ) {
		sys.wait( 4.45 );
		entityToRemove.stopSound( SND_CHANNEL_ANY, 1 );
		entityToRemove.remove();
	}
	
	//Sets shader parms for dissolving entity and plays sound
	void DissolveEntity( entity entityToDissolve ) {
		float count;
		string currentDissolve;
		
		while ( true ) { //loop to dissolve additional entities referenced by the key dissolve1-dissolve<x>
			if ( entityToDissolve ) {
				entityToDissolve.setShaderParm( 4, -sys.getTime() );
				entityToDissolve.setShaderParm( 5, 1 );
			
				if ( entityToDissolve.getKey( "snd_dissolve" ) != "" ) {
					entityToDissolve.startSound( "snd_dissolve", SND_CHANNEL_ANY, 1 );
				}
			}
			
			count++;
			//add dissolve1-dissolve<x> key to entity that's dissolving to dissolve other entities
			currentDissolve = entityToDissolve.getKey( "dissolve" + count );
					
			thread DelayedRemove( entityToDissolve );
					
			if ( currentDissolve != "" ) {
				entityToDissolve = sys.getEntity( currentDissolve );
			} else {
				return;
			}
		}
	}
	
	//Pulses main ship lights/
	void ShipLightPulse( entity light, entity source, entity flare, float offset ) {
		float fadeTime = 0.75,
			  multiplier = 0.1,
			  waitTime = 0.75;
			
		vector lightColor = light.getVectorKey( "_color" ),
			   sourceColor = source.getVectorKey( "_color" ),
			   flareColor = source.getVectorKey( "_color" );
		
		light.On();
		
		thread crossFadeEnt( light, lightColor * multiplier, lightColor, fadeTime );
		thread crossFadeEnt( source, sourceColor * multiplier, sourceColor, fadeTime );
		thread crossFadeEnt( flare, flareColor * multiplier, flareColor, fadeTime );
		if ( offset > 0 ) {
			sys.wait( offset );
		}
		
		while ( true ) {
			thread crossFadeEnt( light, lightColor * multiplier, lightColor, fadeTime );
			thread crossFadeEnt( source, sourceColor * multiplier, sourceColor, fadeTime );
			thread crossFadeEnt( flare, flareColor * multiplier, flareColor, fadeTime );
			sys.wait( waitTime );
			thread crossFadeEnt( light, lightColor, lightColor * multiplier, fadeTime );
			thread crossFadeEnt( source, sourceColor, sourceColor * multiplier, fadeTime );
			thread crossFadeEnt( flare, flareColor, flareColor * multiplier, fadeTime );
			sys.wait( waitTime );
		}
	}
	
	//Ship light pulse main function
	void ShipPulseLights() {
		thread ShipLightPulse( $rhShipLight1, $rhShipLight1Source, $rhShipLight1Flare, 0.0 );
		thread ShipLightPulse( $rhShipLight2, $rhShipLight2Source, $rhShipLight2Flare, 0.1 );
		thread ShipLightPulse( $rhShipLight3, $rhShipLight3Source, $rhShipLight3Flare, 0.2 );
		thread ShipLightPulse( $rhShipLight4, $rhShipLight4Source, $rhShipLight4Flare, 0.3 );
		thread ShipLightPulse( $rhShipLight5, $rhShipLight5Source, $rhShipLight5Flare, 0.4 );
		thread ShipLightPulse( $rhShipLight6, $rhShipLight6Source, $rhShipLight6Flare, 0.5 );
		thread ShipLightPulse( $rhShipLight7, $rhShipLight7Source, $rhShipLight7Flare, 0.6 );
		thread ShipLightPulse( $rhShipLight8, $rhShipLight8Source, $rhShipLight8Flare, 0.7 );
		thread ShipLightPulse( $rhShipLight9, $rhShipLight9Source, $rhShipLight9Flare, 0.8 );
		thread ShipLightPulse( $rhShipLight10, $rhShipLight10Source, $rhShipLight10Flare, 0.9 );
		$rhShipLight11.On();
		$rhShipLight12.On();
		$rhShipLight13.On();
		$rhShipLight14.On();
		$rhShipLight15.On();
		$rhShipLight16.On();
	}
	
	//Pulses green ship lights
	void ShipGreenLightPulse( entity light, float offset ) {
		float fadeTime = 0.5,
			  multiplier = 0.2,
			  waitTime = 0.5;
			  
		vector lightColor = light.getVectorKey( "_color" );
			   
		light.On();
		
		thread crossFadeEnt( light, lightColor * multiplier, lightColor, fadeTime );
		if ( offset > 0 ) {
			sys.wait( offset );
		}
		
		while ( true ) {
			thread crossFadeEnt( light, lightColor, lightColor * multiplier, fadeTime );
			sys.wait( waitTime );
			thread crossFadeEnt( light, lightColor * multiplier, lightColor, fadeTime );
			sys.wait( waitTime );
		}
	}
	
	//Ship green light pulse main function
	void ShipPulseGreenLights() {
		thread ShipGreenLightPulse( $rhShipGreenLight1, 0.0 );
		thread ShipGreenLightPulse( $rhShipGreenLight2, 0.0 );
		thread ShipGreenLightPulse( $rhShipGreenLight3, 0.5 );
		thread ShipGreenLightPulse( $rhShipGreenLight4, 0.5 );
	}
	
	//Plays random roof wood shake sound
	void BuildingCrackSounds() {
		float currentSpeaker;
		
		while ( true ) {
			sys.wait( 1 + sys.random( 2 ) );
			
			currentSpeaker = int( sys.random( 5 ) );
			if ( currentSpeaker == 0 ) {
				$rhRoofWoodShake1.On();
			}
			else if ( currentSpeaker == 1 ) {
				$rhRoofWoodShake2.On();
			}
			else if ( currentSpeaker == 2 ) {
				$rhRoofWoodShake3.On();
			}
			else if ( currentSpeaker == 3 ) {
				$rhRoofWoodShake4.On();
			}
			else {
				$rhRoofWoodShake5.On();
			}
		}
	}
	
	//Randomly plays dog bark sound
	void DogBarkRun() {	
		while ( !gAbducting ) {
			sys.wait( 30 + sys.random( 10 ) );
			$rhDogBarkSpeaker.On();
		}
	}
	
	//Randomly plays wolf howl sound
	void WolfHowlRun() {
		entity currentHowl;
		float howlNum;
		
		while ( !gAbducting ) {
			sys.wait( 30 + sys.random( 10 ) );
			
			howlNum = int( sys.random( 5 ) ) + 1;
			
			currentHowl = sys.getEntity( "rhWolfHowlSpeaker" + howlNum );
			currentHowl.On();
		}
	}
	
	void PassBySoundPlay( entity carCtrlP, entity destNode ) {
		float soundNum = int( sys.random( 6 ) ) + 1;
		float soundPlayCheck = int( sys.random( 3 ) );
		
		if ( soundPlayCheck == 1 ) {
			if ( soundNum == 1 ) {
				$carPassBy1Speaker.On();
				TimeTweak( carCtrlP, 0.25, 0, 7 );
			}
			else if ( soundNum == 2 ) {
				$carPassBy2Speaker.On();
				TimeTweak( carCtrlP, 0, 3, 6 );
			}
			else if ( soundNum == 3 ) {
				$carPassBy3Speaker.On();
				TimeTweak( carCtrlP, 0, 0, 7 );
			}
			else if ( soundNum == 4 ) {
				$carPassBy4Speaker.On();
				TimeTweak( carCtrlP, 0.5, 0, 10 );
			}
			else if ( soundNum == 5 ) {
				$carPassBy5Speaker.On();
				TimeTweak( carCtrlP, 0, 0, 7 );
			}
			else if ( soundNum == 6 ) {
				$carPassBy6Speaker.On();
				TimeTweak( carCtrlP, 0, 0.25, 10 );
			}
		}
		
		carCtrlP.moveTo( destNode );
		sys.waitFor( carCtrlP );
		sys.wait( 1 );
	}
	
	void CarPassBy() {
		entity carCtrlP = $carPassBy1CtrlP;
		
		TimeTweak( carCtrlP, 0, 0, 10 );
		
		while ( carCtrlP.getFloatKey( "isRunning" ) ) {
			PassBySoundPlay( carCtrlP, $carPassByNode2 );
			PassBySoundPlay( carCtrlP, $carPassByNode1 );
		}
	}
	
