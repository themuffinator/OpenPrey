	}
	
	//Truck smashes through roadhouse roof and floor
	void TruckSmash() {
		sys.trigger( $rhTruckClip );
				
		TimeTweak( $rhTruck2, 0, 0, 0.001 );
		$rhTruck2.rotateTo( '50 -15 -5' );
		sys.waitFor( $rhTruck2 );
		$rhTruck2.show();
		TimeTweak( $rhTruck2, 0.55, 0.05, 0.8 );
		$rhTruck2.moveTo( $rhTruckCrashNode2 );
		
		sys.wait( 0.2 );
		
		$rhTruckCrashSpeaker1.On();
		
		sys.wait( 0.1 );
		thread TruckCeilingSmash();
		thread LightPulsateTruck();
		sys.wait( 0.45 );
		thread TruckFloorSmash();
		sys.wait( 0.05 );
		sys.waitFor( $rhTruck2 );
		
		//fall
		$rhGirlfriend.allowMovement( 1 );
		thread SpeechTransition_Blend( $rhGirlfriend, "cower", "cower_idle", 8 );
		thread SpeechTransition_Blend( $rhGrandfather, "takecover", "coweridle", 24 );
		
		TimeTweak( $rhTruck2, 0.1, 0.0, 0.2 );
		$rhTruck2.rotateOnce( '25 0 0' );
				
		sys.trigger( $rhSwingDoor1Moveable1 );
		sys.trigger( $rhSwingDoor1Moveable2 );
		sys.trigger( $rhSwingDoor1Moveable3 );
		sys.trigger( $rhSwingDoor1Moveable4 );
		sys.trigger( $rhSwingDoor2Moveable1 );
		sys.trigger( $rhSwingDoor2Moveable2 );
		sys.trigger( $rhSwingDoor2Moveable3 );
		sys.trigger( $rhSwingDoor2Moveable4 );
		
		sys.waitFrame();
		
		$rhSwingDoor1.remove();
		$rhSwingDoor2.remove();
		
		sys.waitFor( $rhTruck2 );
		
		sys.trigger( $rhTruckForcefield );
		
		sys.trigger( $rhTruckDust1 );
		sys.trigger( $rhTruckDust2 );
		sys.trigger( $rhTruckDust3 );
		sys.trigger( $rhTruckDust4 );
		$rhTruckCrashSpeaker2.On();
		$rhTruckAlarmSpeaker.Off();
				
		sys.waitFor( $rhTruck2 );
		
		sys.trigger( $rhTruckDoorFrame1_2 );
		sys.trigger( $rhTruckDoorFrame1_3 );
		sys.trigger( $rhTruckDoorFrame1_4 );
		
		sys.trigger( $rhTruckDoorTrim1_2 );
		
		sys.waitFrame();
		sys.trigger( $rhTruckDoorTrim1_1 );
		sys.trigger( $rhTruckDoorFrame1_1 );
		
		sys.trigger( $rhTruckShelf1_1 );
		sys.trigger( $rhTruckShelf1_2 );
		
		TimeTweak( $rhTruck2, 0.0, 0.4, 0.4 );
		$rhTruck2.rotateOnce( '-5 2 2' );
	}
	
	//Moves truck alarm sound over to second truck
	void TruckAlarmSoundMove() {
		TimeTweak( $rhTruckAlarmSpeakerCtrlP, 1.5, 1.5, 3 );
		$rhTruckAlarmSpeakerCtrlP.unbind();
		$rhTruckAlarmSpeakerCtrlP.moveTo( $rhTruck2 );
		sys.waitFor( $rhTruckAlarmSpeakerCtrlP );
		$rhTruckAlarmSpeakerCtrlP.bind( $rhTruck2 );
	}
	
	//Flashes truck lights when truck is picked up
	void TruckLightFlash() {
		$rhTruckHeadlightL.On();
		$rhTruckHeadlightR.On();
		
		while ( true ) {
			if ( !CheckSpawnId( $rhTruck, gTruckID ) ) return;
			thread fadeInEnt( $rhTruck, '1 1 1', 0.05 );
			thread fadeInEnt( $rhTruckHeadlightL, '2 2 2', 0.05 );
			thread fadeInEnt( $rhTruckHeadlightR, '2 2 2', 0.05 );
			sys.wait( 0.25 );
			if ( !CheckSpawnId( $rhTruck, gTruckID ) ) return;
			thread fadeOutEnt( $rhTruck, '1 1 1', 0.2 );
			thread fadeOutEnt( $rhTruckHeadlightL, '2 2 2', 0.2 );
			thread fadeOutEnt( $rhTruckHeadlightR, '2 2 2', 0.2 );
			sys.wait( 0.25 );
		}	
	}
	
	//Picks up truck and moves it out of view
	void TruckRemove() {
		thread PlayMapMusic( "snd_roadhouse_abduction_b", false, MUS_TRANSITION_OVERLAP );
		
		TimeTweak( $rhShipProjLightTruckCtrlP, 10, 0, 11 );
		
		$rhShipProjLightTruckCone.show();
		thread fadeInEnt( $rhShipProjLightTruckCone, '1.09 2 1.5294', 1 );
		$rhShipProjLightTruck.On();
		thread fadeInEnt( $rhShipProjLightTruck, '1.09 2 1.5294', 1 );
		
		sys.trigger( $rhShipProjLightTruckConeBeamSpeaker );
			
		thread TruckLightFlash();
		$rhTruckAlarmSpeaker.On();
		sys.wait( 1 );
		
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_LEGS, "abduct_truck", 24 );
		$rhGirlfriend.overrideAnim( ANIMCHANNEL_HEAD );
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_LEGS, "abduct_truck", 24 );
				
		sys.trigger( $rhShipProjLightTruckConeBeamSpeaker2 );
		
		TimeTweak( $rhShipProjLightTruckCtrlP2, 2, 4, 10 );
		$rhShipProjLightTruckCtrlP2.rotateOnce( '20 -64 0' );
		$rhShipProjLightTruckCone2.show();
		thread fadeInEnt( $rhShipProjLightTruckCone2, '1.09 2 1.5294', 1 );
		
		sys.trigger( $rhShipProjLightTruckConeBeamGrabSpeaker );
		$rhShipProjLightTruckCtrlP.rotateOnce( '90 0 0' );
		
		TimeTweak( $rhTruckCtrlP1, 2, 2, 5 );
		$rhTruckCtrlP1.rotateOnce( '20 60 180' );
		
		TimeTweak( $rhTruckCtrlP2, 2, 1, 4 );
		$rhTruckCtrlP2.moveTo( $rhTruckNode1 );
		
		sys.wait( 1 );
			
		sys.waitFor( $rhTruckCtrlP2 );
			
		thread TruckAlarmSoundMove();
		
		TimeTweak( $rhTruckCtrlP2, 2, 0, 2 );
		$rhTruckCtrlP2.moveTo( $rhTruckNode2 );
		sys.waitFor( $rhTruckCtrlP2 );
		$rhTruck.remove();
		
		thread fadeOutEnt( $rhShipProjLightTruckCone2, '1.09 2 1.5294', 1 );
		
		sys.waitFor( $rhShipProjLightTruckCtrlP );
		$rhShipProjLightTruckCone.hide();
		$rhShipProjLightTruck.Off();
	}
	
