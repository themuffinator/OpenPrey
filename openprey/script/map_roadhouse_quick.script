		sys.wait( 1.5 );
		thread DissolveEntity( $rhSupportBeam1 );
		sys.wait( 0.5 );
		thread DissolveEntity( $rhRoofPlank19 );
		sys.wait( 0.5 );
		thread DissolveEntity( $rhRoofPlank20 );
		sys.wait( 3.0 );
		thread DissolveEntity( $rhPayPhoneHandle );
		sys.wait( 0.5 );
		thread DissolveEntity( $rhPayPhoneBase );
		sys.wait( 0.5 );
		thread DissolveEntity( $rhCashRegister );
		sys.wait( 0.5 );
		$rhTV.setSkin( "skins/consoles/bar_tvglass_off" );
