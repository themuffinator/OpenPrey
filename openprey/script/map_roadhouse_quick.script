	void WaitPlayerInBar( float affectPlayerCanSpeak ) {
		vector playerOrigin = $player1.getOrigin();
		
		if ( playerOrigin_x > 64 ) {
			return;
		}
		
		if ( affectPlayerCanSpeak ) {
			TommyCanSpeak();
		}
		
		sys.wait( 0.1 );
		
		while ( true ) {
			playerOrigin = $player1.getOrigin();
			
			if ( playerOrigin_x > 64 ) {
				if ( affectPlayerCanSpeak ) {
					TommyQuiet( FALSE );
				}
				return;
			}
			
			sys.wait( 0.1 );
		}
	}
	
	void WaitPlayerNearBar( float affectPlayerCanSpeak ) {
		vector nearBarOrigin = $rhNearBar.getOrigin();
		float currentDistance = DistanceToXY( $player1.getOrigin(), nearBarOrigin );
		
		if ( currentDistance < 312 ) {
			return;
		}
		
		if ( affectPlayerCanSpeak ) {
			TommyCanSpeak();
		}
		
		sys.wait( 0.1 );
		
		while ( true ) {
			currentDistance = DistanceToXY( $player1.getOrigin(), nearBarOrigin );
			if ( currentDistance < 312 ) {
				if ( affectPlayerCanSpeak ) {
					TommyQuiet( FALSE );
				}
				return;
			}
			
			sys.wait( 0.1 );
		}
	}
		
