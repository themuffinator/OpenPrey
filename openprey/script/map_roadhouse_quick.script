	//waits for player1 to finish speaking, starts dialog mode
	//if instant is set to TRUE the line is not guaranteed to be spoken
	boolean TommyQuiet( float instant ) {
		float maxWaitTime = 20,
			  maxWaitTimeFrames,
			  i;
					  
		if ( !instant ) {
			maxWaitTimeFrames = int( ( maxWaitTime / sys.getFrameTime() ) );
		
			for ( i = 0; i < maxWaitTimeFrames; i++ ) {
				if ( gPlayerCanSpeak ) {
					break;
				}
				sys.waitFrame();
			}
		} else {
			if ( !gPlayerCanSpeak ) {
				return false;
			}
		}
		gPlayerCanSpeak = 0;
		$player1.dialogStart( true, true, false );
		
		return true;
	}

	//ends dialog mode and adds delay between speaking
	void TommyCanSpeak() {
		$player1.dialogStop();
				
		sys.wait( 0.25 ); //min delay for sound ducking
		
		gPlayerCanSpeak = 1;
	}
	
	float DistanceToXY( vector ent1, vector ent2 ) {
		float lengthX = ent1_x - ent2_x,
			  lengthY = ent1_y - ent2_y;
		
		return sys.sqrt( ( lengthX * lengthX ) + ( lengthY * lengthY ) );
	}
	
	boolean CheckDistance( entity npc, entity distanceNull, float distance ) {
		float waistJointHandle,
			  distanceNullIsValid = 0;
			  
		vector distanceNullPos = '0 0 0';
		
		if ( !( !distanceNull ) ) {
			distanceNullIsValid = 1;
		}
		
		if ( !distanceNullIsValid ) { 
			waistJointHandle = npc.getJointHandle( "waist" );
			if ( DistanceToXY( $player1.getOrigin(), npc.getJointPos( waistJointHandle ) ) < distance ) {
				return true;
			}
		} else {
			distanceNullPos = distanceNull.getOrigin();
			if ( DistanceToXY( $player1.getOrigin(), distanceNullPos ) < distance ) {
				return true;
			}
		}
		
		return false;
	}
	
	void WaitDistance( entity npc, entity distanceNull, float checkCanSee, string assetPrefix, float numAssets, float assetsAreSounds, float preDelay, float affectPlayerCanSpeak, float continueRange, float resumeRange, float callbackRange ) {
		float assetNum = 1 + int( sys.random( numAssets ) ),
			  count = 1,
			  nextBeckonTime = sys.getTime() + preDelay,
			  waistJointHandle,
			  currentDistance,
			  soundLength,
			  distanceNullIsValid = 0;
			  
		vector distanceNullPos = '0 0 0';
			  
		if ( !( !distanceNull ) ) {
			distanceNullIsValid = 1;
		}
		
		if ( !distanceNullIsValid ) {  
			waistJointHandle = npc.getJointHandle( "waist" );
			currentDistance = DistanceToXY( $player1.getOrigin(), npc.getJointPos( waistJointHandle ) );
		} else {
			distanceNullPos = distanceNull.getOrigin();
			currentDistance = DistanceToXY( $player1.getOrigin(), distanceNullPos );
		}
		
		if ( currentDistance < continueRange ) { //if within continueRange distance continue conversation without callbacks
			if ( checkCanSee ) {
				if ( npc.getHead().playerCanSee() ) {
					return;
				}
			} else {
				return;
			}
		}
		
		if ( affectPlayerCanSpeak ) {
			TommyCanSpeak();
		}
		
		npc.lookAt( $player1, -1 );
				
		while ( true ) {			
			sys.wait( 0.1 );
			
			if ( !distanceNullIsValid ) {  
				currentDistance = DistanceToXY( $player1.getOrigin(), npc.getJointPos( waistJointHandle ) );
			} else {
				currentDistance = DistanceToXY( $player1.getOrigin(), distanceNullPos );
			}
			
			if ( currentDistance < resumeRange ) { //if within resume range, end callbacks and continue conversation
				if ( checkCanSee ) {
					if ( !npc.getHead().playerCanSee() ) {
						continue;
					}
				}
				if ( affectPlayerCanSpeak ) {
					TommyQuiet( FALSE );
				}
				return;
			} else if ( currentDistance < callbackRange ) { //if player is still in callback range continue callbacks
				if ( sys.getTime() > nextBeckonTime ) {
					if ( TommyQuiet( TRUE ) ) {
						if ( assetsAreSounds ) {
							soundLength = npc.startSoundShader( assetPrefix + assetNum, SND_CHANNEL_VOICE );
							if ( soundLength > 0 ) {
								sys.wait( soundLength );
							}
						} else {
							PlayAnim_Blend( npc, ANIMCHANNEL_HEAD, assetPrefix + assetNum, 6 );
							sys.waitForSilence( npc.getHead(), 0 );
						}
						nextBeckonTime = sys.getTime() + ( ( FClamp( count, 1, 30 ) * 10 ) + sys.random( 6 ) );
						count++;
						assetNum++;
						if ( assetNum > numAssets ) {
							assetNum -= numAssets;
						}
						
						TommyCanSpeak();
					}
				}
			}
		}
	}
	
