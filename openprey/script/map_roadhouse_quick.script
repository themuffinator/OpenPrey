	//Stops a roofplank from rattling and blows it off
	void RoofPlankStopRemove( entity roofPlank, entity roofPlankCtrlP, entity roofPlankBottom ) {
		thread DissolveEntity( roofPlank );
		
		sys.wait( 1.25 );
		
		if ( roofPlankBottom != $null_entity ) {
			roofPlankBottom.show();
		}
		
		vector linearVelocity = Vec3Set( sys.random( 50 ) + 650, sys.random( 10 ) - 5, sys.random( 150 ) + 800 ),
			   angularVelocity = Vec3Set( sys.random( 20 ) - 5, sys.random( 80 ) - 25, sys.random( 20 ) - 05 );
		  
		roofPlank.unbind();
	  	
	  	TimeTweak( roofPlank, 0.1, 0.5, 1.25 );
	  	roofPlank.moveToPos( roofPlank.getOrigin() + linearVelocity );
	  	roofPlank.rotate( angularVelocity );
		
	  	roofPlankCtrlP.rotateOnce( Vec3Set( sys.random( 90 ) - 90, 0, 0 ) );
	}
	
	float gRoofPlanksRattle = 1;
	
	//Rattles a roofplank control point
	void RoofPlankRattle( entity roofPlankCtrlP, float rotAmount, entity crackLight ) {
		float currentRot = 1;
		vector crackLightColor = crackLight.getVectorKey( "_color" ) * 0.2,
			   fadeColor;
			   
		crackLight.show();
		
		while ( gRoofPlanksRattle ) {
			fadeColor = crackLightColor * ( currentRot / rotAmount );
			
			TimeTweak( roofPlankCtrlP, 0.1, 0.05, 0.15 );
			fadeInEnt( crackLight, fadeColor, 0.15 );
			roofPlankCtrlP.rotateOnce( Vec3Set( -currentRot, 0, 0 ) );
			sys.wait( 0.15 );
			
			TimeTweak( roofPlankCtrlP, 0.075, 0.0, 0.075 );
			fadeOutEnt( crackLight, fadeColor, 0.075 );
			roofPlankCtrlP.rotateOnce( Vec3Set( currentRot, 0, 0 ) );
			sys.wait( 0.075 );
			
			if ( currentRot < rotAmount ) {
				currentRot += 1;
			}
			sys.wait( sys.getFrameTime() + sys.random( 0.1 ) );
		}
		
		crackLight.hide();
	}
	
	//rattles roof planks up and down
	void RoofRattlePlanks() {
		float rattleDelay = 0.054;
		
		thread RoofPlankRattle( $rhRoofPlank11CtrlP, 4, $rhRoofPlank11CrackLight );
		sys.wait( rattleDelay );
		thread RoofPlankRattle( $rhRoofPlank29CtrlP, 5, $rhRoofPlank29CrackLight );
