		thread DissolveEntity( $fan2Blades );
	}
	
	//turns on lights that pick up objects
	void ShipGrabLightTurnOn( float lightNumber ) {
		entity cone = sys.getEntity( "rhShipProjLightMiddleCone" + lightNumber ),
			   coneVFP = sys.getEntity( "rhShipProjLightMiddleCone" + lightNumber + "VFP" ),
			   light = sys.getEntity( "rhShipProjLightMiddle" + lightNumber ),
			   source = sys.getEntity( "rhShipProjLightMiddelSource" + lightNumber ),
			   flare = sys.getEntity( "rhShipProjLightMiddleCone" + lightNumber + "Flare" ),
			   beamSound = sys.getEntity( "rhShipProjLightMiddleBeam" + lightNumber );

		light.On();
		beamSound.On();
		cone.show();
		coneVFP.show();
		flare.show();
		
		thread fadeInEnt( source, source.getVectorKey( "_color" ), 0.5 );
		thread fadeInEnt( flare, flare.getVectorKey( "_color" ), 0.5 );
		
		thread ShipLightChangeColors( lightNumber, TRUE );
	}
	
	//Removes all moveables from the bar
	void ShipRemoveAll() {
		ShipGrabLightTurnOn( 1 );
		ShipGrabLightTurnOn( 2 );
				
		sys.wait( 1.5 );
		
		thread ShipLight1Remove();
		thread ShipLight2Remove();
	}
	
	//toggle light state
	void RHLightSwitchTypeLight( entity light, float currentState ) {
		float flicker = light.getFloatKey( "rhFlicker" );
		
		vector colorToSet = light.getVectorKey( "_color" );
				
		if ( currentState ) {
			if ( !flicker ) {
				light.setLightParm( 7, 0 );
			}
		} else { //dims light down, doesn't turn off fully
			light.setLightParm( 7, 1 );
				
			if ( !light.getFloatKey( "rhNoDim" ) ) {
				colorToSet *= 0.1;
			} else {
				colorToSet = '0 0 0';
			}
		}
		
		light.setColor( colorToSet_x, colorToSet_y, colorToSet_z );
		
		if ( currentState && !flicker ) {
			sys.wait( 0.5 );
			
			//lessens the amount the light reacts to sound
			//the light flickers a decent amount when first turned on
			light.setLightParm( 7, 1 );
		}
	}
	
	//toggle light source state
	void RHLightSwitchTypeSource( entity source, float currentState ) {
		float flicker = source.getFloatKey( "rhFlicker" );		
		
		if ( !flicker ) {
			if ( currentState ) {
				source.setShaderParm( 7, 0 );
				sys.wait( 0.5 );
				source.setShaderParm( 7, 1 );
			} else {
				source.setShaderParm( 7, 2 );
			}
		}
	}
	
	//toggle light flare state
	void RHLightSwitchTypeFlare( entity flare, float currentState ) {
		if ( currentState ) {
			thread fadeInEnt( flare, flare.getVectorKey( "_color" ), 1 );
		} else {
			thread fadeOutEnt( flare, flare.getVectorKey( "_color" ), 0.25 );
		}
	}
	
	//toggle light speaker state
	void RHLightSwitchTypeSpeaker( entity speaker, float currentState ) {
		if ( currentState ) {
			speaker.On();
		} else {
			speaker.Off();
		}
	}
	
	//toggle light particle state
	void RHLightSwitchTypeParticle( entity particle, float currentState ) {
		sys.trigger( particle );
	}
		
	void RHLightSwitchMisc( entity switch ) {
		if ( switch.getFloatKey( "triggerGames" ) ) {
			string gameGuiEvent;
			
			if ( switch.getKey( "currentState" ) == "on" ) {
				gameGuiEvent = "TurnOn";
			} else {
				gameGuiEvent = "TurnOff";
			}
			
			$rhGameBlackJackConsole.guiEvent( gameGuiEvent );
			$rhGamePokerConsole.guiEvent( gameGuiEvent );
			$rhGameSlotsConsole.guiEvent( gameGuiEvent );
			$rhGameArcadeConsole.guiEvent( gameGuiEvent );
		}
	}
	
	//Rotates a light switch and triggers / fades all appropriate entities
	//lights that don't flicker should have shaderparm7 set to 1, along with the light source
	void RHLightSwitch( entity switch, entity console ) {
		if ( !switch.getFloatKey( "isRunning" ) ) {
			switch.setKey( "isRunning", 1 );
			
			float currentState; //switches current state, 0 = off, 1 = on
			
			//swap gui hand press anim
			if ( console.getKey( "pressAnim" ) == "press_down" ) {
				console.setKey( "pressAnim", "press_up" );
			} else {
				console.setKey( "pressAnim", "press_down" );
			}
			
			//rotate switch
			if ( switch.getKey( "currentState" ) == "on" ) {
				switch.rotateOnce( '48 0 0' );
				switch.setKey( "currentState", "off" );
				currentState = 0;
			} else {
				switch.rotateOnce( '-48 0 0' );
				switch.setKey( "currentState", "on" );
				currentState = 1;
			}
			switch.startSound( "snd_switch", SND_CHANNEL_ANY, 0 );
			sys.waitFor( switch );
			
			//"disabled" is set on the switch when the lights in roadhouse go out, lights turning off is handled elsewhere
			if ( !switch.getFloatKey( "disabled" ) ) {				
				entity lightRelay = sys.getEntity( switch.getKey( "target" ) ),
					   currentEnt;
				
				float relayNumTargets = lightRelay.numTargets(),
					  i;
					  
				string className;
				
				for ( i = 0; i < relayNumTargets; i++ ) {
					if ( currentEnt = lightRelay.getTarget( i ) ) {
						className = currentEnt.getKey( "classname" );
				
						if ( className == "light" ) {
							thread RHLightSwitchTypeLight( currentEnt, currentState );
						}
						else if ( className == "func_static" || className == "env_hanglight_bar" ) {
							if ( currentEnt.getFloatKey( "rhFlare" ) == 0 ) {
								thread RHLightSwitchTypeSource( currentEnt, currentState );
							} else {
								thread RHLightSwitchTypeFlare( currentEnt, currentState );
							}
						}
						else if ( className == "speaker" ) {
							thread RHLightSwitchTypeSpeaker( currentEnt, currentState );							
						}
						else if ( className == "func_emitter" ) {
							thread RHLightSwitchTypeParticle( currentEnt, currentState );							
						}
						else {
							sys.println( currentEnt.getName() + "RHLightSwitch unknown type - classname: " + className );
						}
					}
				}				
				
				RHLightSwitchMisc( switch );
			}

			sys.wait( 0.5 );
			
			switch.setKey( "isRunning", 0 );			
		}
	}
	
