	void AbductionStart() {
		gAbducting = 1; //set global abducting so unnecessary threads end
		
		$player1.dialogStart( true, false, false );
		
		JukeBoxPlayAbduction();
		sys.wait( 2 );
		
		thread TruckRemove();
		sys.wait( 9 );
		$rhShipEntryTrigger.enable();
	}
	
	void ShipEntryDialog() {
		//Jenny "We've got to get out of here!"
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_HEAD, "jn_roadhouse_wevegot", 6 );
		sys.waitForSilence( $rhGirlfriend.getHead(), 1 );
		
		//Tommy "Enisi?"
		$player1.startSoundShader( "rh_conv8_tom06", SND_CHANNEL_VOICE );
		sys.waitForSilence( $player1, 1 );
		
