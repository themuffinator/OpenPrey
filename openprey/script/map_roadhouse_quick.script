namespace map_roadhouse {
	float gAbducting = 0; //set to 1 once the abduction starts taking place
	float gPlayerCanSpeak = 1;
	float gChuckDaltonBusy = 0;
	float gFansSpin = 1;
	float gDaltonID;
	float gChuckID;
	float gTruckID;
