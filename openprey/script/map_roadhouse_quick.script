	//Second lights item removal
	void ShipLight2Remove() {
		sys.wait( 1.2 );
		
		$rhStool3Top.bind( $rhStool3 );
		$rhStool3Clip.remove();
		thread ShipRemove1Node( "rhStool3", '2 2 6', 0.5, 2 );
