	//Snaps a lightswitch to the on position
	void RHLightSwitchSnapOn( entity switch ) {
		switch.setAngles( switch.getAngles() + '-24 0 0' );
		switch.setKey( "currentState", "on" );
		TimeTweak( switch, 0.025, 0, 0.1 );
	}
	
	//Snaps a lightswitch to the off position and turns off lights
	void RHLightSwitchSnapOff( entity switch ) {
		switch.setAngles( switch.getAngles() + '24 0 0' );
		switch.setKey( "currentState", "off" );
		
		sys.trigger( sys.getEntity( switch.getKey( "target" ) ) ); //lights on by default, trigger switch target to turn off
		
		TimeTweak( switch, 0.025, 0, 0.1 );
	}
	
	//sets all lights, sources, and flares parm7 appropriately based on whether or not they flicker
	void RHLightParm7Setup( entity lightRelay ) {
		entity currentEnt;
				
		float relayNumTargets = lightRelay.numTargets(),
			  i;
		
		string className;
		
		for ( i = 0; i < relayNumTargets; i++ ) {
			if ( currentEnt = lightRelay.getTarget( i ) ) {
				className = currentEnt.getKey( "classname" );
				
				if ( className == "light" ) {
					if ( currentEnt.getFloatKey( "rhFlicker" ) ) {
						currentEnt.setLightParm( 7, 0 );
					} else {
						currentEnt.setLightParm( 7, 1 );
					}
				} else if ( className == "func_static" && currentEnt.getFloatKey( "rhFlare" ) == 0 ) {
					if ( currentEnt.getFloatKey( "rhFlicker" ) ) {
						currentEnt.setShaderParm( 7, 0 );
					} else {
						currentEnt.setShaderParm( 7, 1 );
					}
				}
			}
		}
	}
	
	//Main light switch setup
	void RHLightSetup() {
		RHLightSwitchSnapOn( $rhLightSwitch2 );
		RHLightSwitchSnapOn( $rhLightSwitch2b );
		RHLightSwitchSnapOn( $rhLightSwitch3 );
		RHLightSwitchSnapOn( $rhLightSwitch4 );
		RHLightSwitchSnapOn( $rhLightSwitch5 );
		RHLightSwitchSnapOn( $rhLightSwitch6 );
		RHLightSwitchSnapOn( $rhLightSwitch8 );
		RHLightSwitchSnapOn( $rhLightSwitch9 );
		RHLightSwitchSnapOn( $rhLightSwitch10 );
		
		RHLightParm7Setup( $rhLightSwitch1Relay );
		RHLightParm7Setup( $rhLightSwitch2Relay );
		RHLightParm7Setup( $rhLightSwitch3Relay );
		RHLightParm7Setup( $rhLightSwitch4Relay );
		RHLightParm7Setup( $rhLightSwitch5Relay );
		RHLightParm7Setup( $rhLightSwitch6Relay );
		RHLightParm7Setup( $rhLightSwitch8Relay );
		RHLightParm7Setup( $rhLightSwitch9Relay );
		RHLightParm7Setup( $rhLightSwitch10Relay );
		RHLightParm7Setup( $rhLightSwitch11Relay );
		
		$rhLightSwitch10Base.guiEvent( "TurnOff" ); //disable light switch near grandfather
	}
	
	//disables all light switches and turns off all lights, sources, particles, sounds, and speakers
	void DisableLightSwitches() {
		float i,
		      j,
		      relayNumTargets;
		      			   
		entity lightRelay,
			   currentSwitch,
			   currentEnt;
			   
		string className;
		
		for ( i = 1; i <= 12; i++ ) {
			if ( currentSwitch = sys.getEntity( "rhLightSwitch" + i ) ) {
				currentSwitch.setKey( "disabled", 1 );
			}
			
			lightRelay = sys.getEntity( "rhLightSwitch" + i + "Relay" );
			
			relayNumTargets = lightRelay.numTargets();
			for ( j = 0; j < relayNumTargets; j++ ) {
				if ( currentEnt = lightRelay.getTarget( j ) ) {
					className = currentEnt.getKey( "classname" );
					
					if ( className == "light" || className == "speaker" ) {
						currentEnt.Off();
					}
					else if ( className == "func_static" || className == "env_hanglight_bar" || className == "func_emitter" ) {
						currentEnt.setColor( 0, 0, 0 );
					}
				}
			}
		}
	}
	
	void AppliancesTurnOff() {
		$rhFridgeLeft.setColor( 0.0, 0.0, 0.0 );
		$rhFridgeLeftTop.setColor( 0.0, 0.0, 0.0 );
		$rhFridgeRight.setColor( 0.0, 0.0, 0.0 );
		$rhFridgeRightTop.setColor( 0.0, 0.0, 0.0 );
		
		$rhClock.setSkin( "skins/consoles/guitoflatblack" );
		
		$rhExitSign.setShaderParm( 7, 1 );
		$rhExitSignLight.Off();
		$rhExitSignSpeaker.Off();
				
		$rhTV.stopSound( SND_CHANNEL_ANY, 0 ); //stop static sound
		$rhTV.guiEvent( "TurnOff" );
		$rhTV.stopSound( SND_CHANNEL_ANY, 1 );
	}
		
	void HangLightSpark( float lightNum ) {
		entity sparkRelay = sys.getEntity( "rhLight1_" + lightNum + "SparkRelay" ),
			   lightSource = sys.getEntity( "rhLightBulb1_" + lightNum ),
			   light = sys.getEntity( "rhLight1_" + lightNum );
		
		sys.trigger( sparkRelay );
		lightSource.startSound( "snd_blowout", SND_CHANNEL_ANY, 1 );
		light.On();
		light.setColor( 2.0, 2.0, 2.0 );
		lightSource.setColor( 2.0, 2.0, 2.0 );
		sys.wait( 0.075 );
		light.Off();
		lightSource.setColor( 0.0, 0.0, 0.0 );
		sys.wait( 0.05 );
		light.On();
		lightSource.setColor( 2.0, 2.0, 2.0 );
		sys.wait( 0.05 );
		light.Off();
		lightSource.setColor( 0.0, 0.0, 0.0 );
		sys.wait( 0.025 );
		light.On();
		lightSource.setColor( 2.0, 2.0, 2.0 );
		sys.wait( 0.04 );
		light.Off();
		lightSource.setColor( 0.0, 0.0, 0.0 );
		
	}
	
	void PowerOutage() {
		DisableLightSwitches();
		
		AppliancesTurnOff();
		
		//dim windows environment map
		sys.trigger( $window1Dim );
		sys.trigger( $window2Dim );
		sys.trigger( $window3Dim );
				
		sys.waitFrame();
		HangLightSpark( 1 );
		HangLightSpark( 2 );
		HangLightSpark( 3 );
	}
		
