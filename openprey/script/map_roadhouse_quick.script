	//dissolves beer bottles, mugs, cans, ashtrays, etc
	void DissolveSmallMovables() {
		float i,
			  numMovables = $rhSmallMovablesToDissolve.numTargets();
		
		for ( i = 0; i < numMovables; i++ ) {
			thread DissolveEntity( $rhSmallMovablesToDissolve.getTarget( i ) );
			sys.wait( 0.3 );
		}
	}
	
	//Main function for ship dissolving items in bar that aren't picked up
	void ShipDissolve() {
		//hang lights
		thread DissolveEntity( $rhLightBulb1_2 );
