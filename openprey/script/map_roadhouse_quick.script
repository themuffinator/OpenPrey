	//Toggles bathroom toilet lid up and down
	void BathToiletLidToggle( entity gui, entity lid ) {
		if ( lid.getFloatKey( "isRunning" ) == 0 ) {
			lid.setKey( "isRunning", 1 );
			
			//swap gui hand press anim
			if ( gui.getKey( "pressAnim" ) == "press_down" ) {
				gui.setKey( "pressAnim", "press_up" );
			} else {
				gui.setKey( "pressAnim", "press_down" );
			}
			
			if ( lid.getKey( "currentState" ) == "closed" ) {
				TimeTweak( lid, 0.35, 0.1, 0.75 );
				lid.rotateOnce( '-87 0 0' );
				lid.setKey( "currentState", "open" );
				sys.waitFor( lid );
				lid.startSound( "snd_lidup", SND_CHANNEL_ANY, 1 );
			}
			else {
				TimeTweak( lid, 0.45, 0.05, 0.65 );
				lid.rotateOnce( '87 0 0' );
				lid.setKey( "currentState", "closed" );
				sys.waitFor( lid );
				lid.startSound( "snd_liddown", SND_CHANNEL_ANY, 1 );
			}
			
			lid.setKey( "isRunning", 0 );
		}
	}
	
