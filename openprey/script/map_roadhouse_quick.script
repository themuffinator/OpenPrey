	void WaterHeaterSetup() {
		TimeTweak( $rhWaterHeater, 0.025, 0.025, 0.075 );
	}
	
	float gWaterHeaterState = 1;
	
	void WaterHeaterShake() {
		while ( gWaterHeaterState == 1 && $rhWaterHeater.getKey( "powerCycle" ) == "on" ) {
			$rhWaterHeater.rotateOnce( '0 0.2 0.1' );
			sys.wait( 0.075 );
			$rhWaterHeater.rotateOnce( '0 -0.2 -0.1' );
			sys.wait( 0.075 );
		}
	}
	
	//movement / sound for water heater on
	void WaterHeaterTurnOn() {
		if ( gWaterHeaterState == 1 ) {
			thread WaterHeaterShake();
			$rhWaterHeater.startSound( "snd_running", SND_CHANNEL_ANY, 1 );
		}
	}
	
	//stops movement / sound
	void WaterHeaterTurnOff() {
		$rhWaterHeater.stopSound( SND_CHANNEL_ANY, 1 );
	}
	
	//Main water heater controlling function
	void WaterHeaterRun() {
		while ( !gAbducting ) {
			$rhWaterHeater.setKey( "powerCycle", "on" );
			WaterHeaterTurnOn();
			sys.wait( 60 );
			
			$rhWaterHeater.setKey( "powerCycle", "off" );
			WaterHeaterTurnOff();
			sys.wait( 30 );
		}
	}
	
	//Toggles water heater on/off state
	void WaterHeaterToggle() {
		if ( $rhWaterHeaterFlare.getFloatKey( "isRunning" ) == 0 ) {
			$rhWaterHeaterFlare.setKey( "isRunning", 1 );
			
			$rhWaterHeaterSpeaker.On();
			
			vector colorValue = $rhWaterHeaterFlare.getVectorKey( "_color" ),
				   sourceColorValue = $rhWaterHeaterSource.getVectorKey( "_color" );
								
			if ( gWaterHeaterState == 1 ) {
				gWaterHeaterState = 0;
				$rhWaterHeaterLight.Off();
				thread fadeOutEnt( $rhWaterHeaterFlare, colorValue, 0.1 );
				thread fadeOutEnt( $rhWaterHeaterSource, sourceColorValue, 0.1 );
				WaterHeaterTurnOff();
			}
			else {
				gWaterHeaterState = 1;
				$rhWaterHeaterLight.On();
				thread fadeInEnt( $rhWaterHeaterFlare, colorValue, 0.1 );
				thread fadeInEnt( $rhWaterHeaterSource, sourceColorValue, 0.1 );
				if ( $rhWaterHeater.getKey( "powerCycle" ) == "on" ) {
					WaterHeaterTurnOn();
				}
			}
			
			sys.wait( 0.25 );
			$rhWaterHeaterFlare.setKey( "isRunning", 0 );
		}
	}
	
	//Called when player uses soap dispenser
	void BathSoapUse( entity handle, entity emitter, entity speaker ) {		
		if ( !handle.getFloatKey( "isRunning" ) ) {
			handle.setKey( "isRunning", 1 );
		
			speaker.On();
			TimeTweak( handle, 0.05, 0.1, 0.15 );
			handle.rotateOnce( '17 0 0' );
			sys.trigger( emitter );
			sys.waitFor( handle );
			sys.wait( 0.05 );
			TimeTweak( handle, 0.05, 0.1, 0.35 );
			handle.rotateOnce( '-17 0 0' );
			sys.waitFor( handle );
			sys.wait( 0.5 );
			
			handle.setKey( "isRunning", 0 );
		}
	}
	
