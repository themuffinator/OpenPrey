	void Conversation1GrandfatherEnter() {
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_LEGS, "rh_hallway_idle_to_grandfather", 0 );
		sys.trigger( $rhGrandfatherForce1 );
		sys.wait( $rhGrandfather.animLength( ANIMCHANNEL_LEGS, "rh_hallway_idle_to_grandfather" ) );
		PlayCycle_Blend( $rhGrandfather, ANIMCHANNEL_LEGS, "rh_hallway_idle_grandfather", 12 );
	}
	
	void Conversation1DoorSwingExitThread() {
		$rhSwingDoor1CtrlP.time( 0.5 );
		$rhSwingDoor2CtrlP.time( 0.5 );
		
		$rhSwingDoor1CtrlP.rotateOnce( '0 90 0' );
		$rhSwingDoor2CtrlP.rotateOnce( '0 -90 0' );
		sys.wait( 2 );
		$rhSwingDoor1CtrlP.rotateOnce( '0 -90 0' );
		$rhSwingDoor2CtrlP.rotateOnce( '0 90 0' );
		sys.waitFor( $rhSwingDoor1CtrlP );
		$rhSwingDoor1.unbind();
		$rhSwingDoor2.unbind();
	}
	
	void Conversation1DoorSwingExit() {
		thread Conversation1DoorSwingExitThread();
	}
	
	void Conversation1GrandfatherExit() {
		thread SpeechTransition_Blend( $rhGrandfather, "rh_idle_to_grandfather", "rh_idle_grandfather", 48 );
		sys.wait( 3 );
		$rhGrandfather.lookAt( $null_entity, 0 );
		
		$rhLightSwitch10Base.guiEvent( "TurnOn" ); //enable light switch near grandfather
		
		//overrideAnim on head for rh_idle_grandfather
		sys.wait( $rhGrandfather.animLength( ANIMCHANNEL_LEGS, "rh_idle_to_grandfather" ) - 3 );		
		$rhGrandfather.overrideAnim( ANIMCHANNEL_HEAD );
	}
	
	void RemoveGrandfatherClipThread() {
		$rhGrandfatherClip1.speed( 21 );
		$rhGrandfatherClip1.move( EAST, 48 );
		$rhGrandfatherClip2.bindToJoint( $rhGrandfather, "hip", 0 );
		sys.waitFor( $rhGrandfatherClip1 );
		$rhGrandfatherClip1.remove();
		sys.wait( 6 );
		$rhGrandfatherClip2.remove();
	}
	
	void RemoveGrandfatherClip() {
		thread RemoveGrandfatherClipThread();
	}
	
	void Conversation1() {
		$rhGrandfather.lookAt( $player1, -1 );
		
		thread Conversation1GrandfatherEnter();
						
		//Grandfather "Tommy"
		TommyQuiet( FALSE );
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_HEAD, "gf_roadhouse_tommy", 0 );
		sys.waitForSilence( $rhGrandfather.getHead(), 0.35 );
		
		$rhGrandfather.overrideAnim( ANIMCHANNEL_HEAD );
				
		WaitDistanceGFHallway( 1, 4, 1 );
		
		//Tommy "Enisi? What are you doing here? You never come in here."
		$player1.startSoundShader( "rh_conv1_tom02", SND_CHANNEL_VOICE );
		sys.waitForSilence( $player1, 0.15 );
				
		WaitDistanceGFHallway( 0, 2, 1 );
		
		//Grandfather "I sense great change on the winds. I came to warn-"
		PlayCycle_Blend( $rhGrandfather, ANIMCHANNEL_LEGS, "rh_hallway_idle_grandfather", 36 );
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_HEAD, "gf_roadhouse_isense", 2 );
		sys.wait( 3.8 );
		thread SpeechTransition_Blend( $rhGrandfather, "rh_hallway_cametowarn_grandfather", "rh_hallway_idle_B_grandfather", 8 );
		
		WaitDistanceGFHallway( 0, 2, 1 );
		
		//Tommy "Save it, Grandfather. You know I don't go for that shit."
		$player1.startSoundShader( "rh_conv1_tom04", SND_CHANNEL_VOICE );
		sys.waitForSilence( $player1, -0.6 );
		
		WaitDistanceGFHallway( 0, 2, 1 );
		
		$rhGrandfather.overrideAnim( ANIMCHANNEL_HEAD );
		
		//Grandfather "Listen Tommy. You cannot turn your back on your heritage any longer. It will give you strength."
		thread SpeechTransition_Blend( $rhGrandfather, "rh_hallway_calmdown_grandfather", "rh_hallway_idle_C_grandfather", 12 );
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_HEAD, "gf_roadhouse_listentommy", 4 );
		sys.waitForSilence( $rhGrandfather.getHead(), 0.1 );
		
		$rhGrandfather.overrideAnim( ANIMCHANNEL_HEAD );
		
		if ( CheckDistanceGFHallway() ) {
			//Tommy "For what?"
			$player1.startSoundShader( "rh_conv1_tom06", SND_CHANNEL_VOICE );
			sys.waitForSilence( $player1, 0 );
		}
	
		if ( CheckDistanceGFHallway() ) {
			//Grandfather "To save yourself. To survive."
			PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_HEAD, "gf_roadhouse_tosave", 6 );
			thread SpeechTransition_2Blends( $rhGrandfather, "rh_hall_tosave_gf", "rh_hallway_idle_grandfather", 12, 24 );
			sys.waitForSilence( $rhGrandfather.getHead(), 0 );
			
			//Tommy "Uh, thanks for the concern. But I don't need saving. Go home. I gotta help Jen close up."
			$player1.startSoundShader( "rh_conv1_tom08", SND_CHANNEL_VOICE );
			sys.waitForSilence( $player1, 1.0 );
		}
		
		WaitDistanceGFHallway( 0, 2, 1 );
		
		$player1.startSoundShader( "rh_conv1_tom08a", SND_CHANNEL_VOICE );
		sys.wait( 0.25 );
		
		//Grandfather "My place is here, by your side. You will have need of me this night."		
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_HEAD, "gf_roadhouse_myplace", 2 );
		
		sys.waitForSilence( $player1, 0 ); //rh_conv1_tom08a
				
		thread Conversation1GrandfatherExit();
		sys.waitForSilence( $rhGrandfather.getHead(), 0 ); //gf_roadhouse_myplace
		
		
		if ( CheckDistanceGFHallway() ) {
			//Tommy "Sure, whatever."
			$player1.startSoundShader( "rh_conv1_tom10", SND_CHANNEL_VOICE );
			sys.waitForSilence( $player1, 0 );
		}
		
		TommyCanSpeak();
	}
	
	void JukeboxStart() {
		$rhJukeBox.setTrack( 1 );
		$rhJukeBox.playSelected();
	}
	
	void NPCSetup() {
		$rhGrandfather.becomeNonSolid();
		$rhGirlfriend.becomeNonSolid();
		$rhChuck.becomeNonSolid();
		$rhDalton.becomeNonSolid();
		
		$rhGirlfriend.disableClip();
		
		$rhGrandfather.setNeverDormant( 1 );
		$rhGirlfriend.setNeverDormant( 1 );
		$rhChuck.setNeverDormant( 1 );
		$rhDalton.setNeverDormant( 1 );
		
		$rhGrandfather.DisableWalkIK();
		$rhGirlfriend.DisableWalkIK();
		$rhChuck.DisableWalkIK();
		$rhDalton.DisableWalkIK();
		
		$rhGirlfriend.playCycle( ANIMCHANNEL_LEGS, "rh_wash_idle_jenny" );
		$rhChuck.playCycle( ANIMCHANNEL_LEGS, "rh_idle_chuck" );
		$rhDalton.playCycle( ANIMCHANNEL_LEGS, "rh_idle_dalton" );
		
		$rhGrandfather.allowMovement( 1 );
		
		sys.waitFrame();
		
		$rhChuckBeer1.moveToJoint( $rhChuck, "Lattach_gun" );
		$rhChuckBeer1.setAngles( $rhChuck.getJointAngle( $rhChuck.getJointHandle( "Lattach_gun" ) ) + '-90 90 90' );
		$rhChuckBeer1.bindToJoint( $rhChuck, "Lattach_gun", 1 );
		$rhDaltonBeer1.moveToJoint( $rhDalton, "Rattach_gun" );
		$rhDaltonBeer1.setAngles( $rhDalton.getJointAngle( $rhDalton.getJointHandle( "Rattach_gun" ) ) + '0 0 -90' );
		$rhDaltonBeer1.bindToJoint( $rhDalton, "Rattach_gun", 1 );
				
		$rhGirlfriendLookAt.moveToJoint( $rhGirlfriend.getHead(), "head" );
		$rhGirlfriendLookAt.bindToJoint( $rhGirlfriend.getHead(), "head", 1 );
	}
	
	boolean NPCComment( entity npc, string anim, entity self ) {	
		if ( !self.getFloatKey( "hasSpoken" ) ) {			
			if ( TommyQuiet( TRUE ) ) {
				self.setKey( "hasSpoken", 1 );
				self.disable();
				
				PlayAnim_Blend( npc, ANIMCHANNEL_HEAD, anim, 6 );
				npc.lookAt( $player1, npc.animLength( ANIMCHANNEL_HEAD, anim ) );
				sys.waitForSilence( npc.getHead(), 0 );
				TommyCanSpeak();
				return true;
			}
		}
		return false;
	}

	//JEN		Tommy, knock it off! 
	void JenKnockItOff( entity self ) {
		NPCComment( $rhGirlfriend, "jn_roadhouse_tommyknock", self );
	}
	
	//JEN		Tommy, grow up.
	void JenGrowUp( entity self ) {
		NPCComment( $rhGirlfriend, "jn_roadhouse_tommygrow", self );
	}
	
	//CHUCK		Buzz off.
	void ChuckBuzzOff( entity self ) {
		if ( !gChuckDaltonBusy ) {
			gChuckDaltonBusy = 1;
			if ( NPCComment( $rhChuck, "ch_roadhouse_buzzoff", self ) ) {
				thread SpeechTransition_Blend( $rhDalton, "rh_drink_beer_dalton", "rh_idle_dalton", 12 );
				sys.wait( 8 );
				$rh_dalton02.enable();
			}
			gChuckDaltonBusy = 0;
		}
	}
	
	//CHUCK		I said beat it.
	void ChuckBeatIt( entity self ) {
		if ( !gChuckDaltonBusy ) {
			gChuckDaltonBusy = 1;
			if ( NPCComment( $rhChuck, "ch_roadhouse_isaid", self ) ) {	
				thread SpeechTransition_Blend( $rhDalton, "rh_drink_beer_dalton", "rh_idle_dalton", 12 );
				thread SpeechTransition_Blend( $rhChuck, "rh_drink_beer_chuck", "rh_idle_chuck", 12 );
			}
			gChuckDaltonBusy = 0;
		}
	}
	
	//CHUCK		Dalton, look at this guy.
	//DALTON	Get lost asshole
	void ChuckLookAt( entity self ) {
		if ( !gChuckDaltonBusy ) {
			gChuckDaltonBusy = 1;
			if ( NPCComment( $rhChuck, "ch_roadhouse_daltonlook", self ) ) {
				thread SpeechTransition_Blend( $rhChuck, "rh_drink_beer_chuck", "rh_idle_chuck", 12 );
				NPCComment( $rhDalton, "dl_roadhouse_getlost", $rh_dalton01 );
				sys.wait( 8 );
				$rh_chuck01.enable();
			}
			gChuckDaltonBusy = 0;
		}
	}
	
	//DALTON	Fuck off, man
	void DaltonFuckOff( entity self ) {
		if ( !gChuckDaltonBusy ) {
			gChuckDaltonBusy = 1;
			if ( NPCComment( $rhDalton, "dl_roadhouse_fuckoff", self ) ) {
				thread SpeechTransition_Blend( $rhChuck, "rh_drink_beer_chuck", "rh_idle_chuck", 12 );
				sys.wait( 8 );
				$rh_chuck02.enable();
			}
			gChuckDaltonBusy = 0;
		}
	}
	
	boolean TommyComment( string comment, entity self ) {
		if ( !self.getFloatKey( "hasSpoken" ) ) {			
			if ( TommyQuiet( TRUE ) ) {
				self.setKey( "hasSpoken", 1 ); //comment won't be spoken again
				self.disable();
				
				$player1.startSoundShader( comment, SND_CHANNEL_VOICE );
				sys.waitForSilence( $player1, 1 );
				TommyCanSpeak();
				return true;
			}
		}
		return false;
	}
	
	//disables all triggers for Tommy's window comment
	void TommyWindow( entity self, entity sightEnt ) {
		if ( sightEnt.playerCanSee() ) {
			if ( TommyComment( "rh_tom_window", self ) ) {
				//disable all window comment triggers
				$rh_tom11.disable();
				$rh_tom12.disable();
				$rh_tom13.disable();
			}
		}
	}
	
	void TommyWindow1( entity self ) {
		TommyWindow( self, $window1Sight );
	}
	
	void TommyWindow2( entity self ) {
		TommyWindow( self, $window2Sight );
	}
	
	void TommyWindow3( entity self ) {
		TommyWindow( self, $window3Sight );
	}
	
	//TOMMY	Doesn't anyone ever clean this place? 
	void TommyDoesntAnyone( entity self ) {
		TommyComment( "rh_tom01", self );
	}
	
	//TOMMY	Oh, gross.
	void TommyOhGross( entity self ) {
		TommyComment( "rh_tom02", self );
	}
	
	//TOMMY	Sugar and spice, my ass.
	void TommySugarAndSpice( entity self ) {
		TommyComment( "rh_tom03", self );
	}
	
	//TOMMY	Looks like Jen's running low on Ryan Red.
	void TommyLooksLikeJen( entity self ) {
		TommyComment( "rh_tom04", self );
	}
		
	//TOMMY	Worst. Indian casino. Ever.
	void TommyWorstIndianCasino( entity self ) {
		TommyComment( "rh_tom05", self );
	}
		
	//TOMMY	Man, they need some new tunes in this thing.
	void TommyManTheyNeed( entity self ) {		
		if ( $rhJukeBox.playerCanSee() ) {
			if ( TommyComment( "rh_tom06", self ) ) {
				sys.wait( 10 );
				$rh_tom07.enable(); //enable alternate dialog trigger
			}
		}
	}
		
	//TOMMY	Who picks this stuff?
	void TommyWhoPicks( entity self ) {
		if ( $rhJukeBox.playerCanSee() ) {
			TommyComment( "rh_tom07", self );
		}
	}
		
	//TOMMY	I just got here!
	void TommyIJustGotHere( entity self ) {
		if ( TommyComment( "rh_tom08", self ) ) {
			sys.wait( 15 );
			$rh_tom09.enable(); //enable alternate dialog trigger
		}
	}
		
	//TOMMY	I can�t leave yet
	void TommyICantLeave( entity self ) {
		TommyComment( "rh_tom09", self );
	}
	
	//TOMMY	(laughs) Man, Jen�s let this place slide�
	void TommyManJens( entity self ) {
		TommyComment( "rh_tom10", self );
	}
	
	//sets global shader parms used for dissolve effect
	void SetGlobalShaderParms() {
		sys.setShaderParm( 6, 0.3 );
		sys.setShaderParm( 7, 0.075 );
	}
	
	void SetEntityIDs() {
		gDaltonID = sys.getEntitySpawnId( $rhDalton );
		gChuckID = sys.getEntitySpawnId( $rhChuck );
		gTruckID = sys.getEntitySpawnId( $rhTruck );
	}
	
	void IntroMusicPlay() {
		thread PlayMapMusic( "snd_roadhouse_flashback", false, MUS_TRANSITION_CUTOFF );
	}
	
	void VoiceIntro() {
		sys.fadeOut( '0 0 0', sys.getFrameTime() );
		sys.wait( 1.5 );
		$player1.startSoundShader( "rh_intro1", SND_CHANNEL_VOICE );
		sys.waitForSilence( $player1, -1.5 );
		$player1.startSoundShader( "rh_intro2", SND_CHANNEL_VOICE );
		sys.waitForSilence( $player1, -1.5 );
		$player1.startSoundShader( "rh_intro3", SND_CHANNEL_VOICE );
		sys.waitForSilence( $player1, -4.5 );
	}

	
	void CameraTrack( entity head ) {
		$rhIntroCameraCtrlP.unbind();
		
		while ( gCameraTrack ) {
			$rhIntroCameraCtrlP.setOrigin( head.getJointPos( head.getJointHandle( "camera" ) ) );
			$rhIntroCameraCtrlP.setAngles( head.getJointAngle( head.getJointHandle( "camera" ) ) );
			sys.waitFrame();
		}
	}
	
	void PlayerSetup() {
		$player1.cinematic( 1, 1 );
		
		$rhIntroCamera.setAngles( '-3.39 -3.94 -1.43' ); //offset the camera a bit from the joint
		$rhIntroCamera.bind( $rhIntroCameraCtrlP );
		sys.wait( 2 );
		
		$player1.setPrivateCameraView( $rhIntroCamera, 1 );
		$rhIntroCamera.setfov( 80, 0, 0, 0 );
		
		entity player1Head = $player1.getHead();
		
		$rhIntroCameraCtrlP.setAngles( player1Head.getJointAngle( player1Head.getJointHandle( "camera" ) ) );
		$rhIntroCameraCtrlP.moveToJoint( player1Head, "camera" );
		$rhIntroCameraCtrlP.bind( player1Head );
		$rhIntroCameraCtrlP.bindToJoint( player1Head, "camera", 1 );
		sys.waitFrame();
		
		thread CameraTrack( player1Head );
			
		$player1.setBlendFrames( ANIMCHANNEL_TORSO, 0 );
		$player1.setBlendFrames( ANIMCHANNEL_LEGS, 0 );
		$player1.playCycle( ANIMCHANNEL_TORSO, "rh_mirror_preidle_tommy" );
		$player1.playCycle( ANIMCHANNEL_LEGS, "rh_mirror_preidle_tommy" );
	}

	void QuickStartMirrorControl() {
		// End intro camera tracking and restore direct player control immediately.
		gCameraTrack = 0;
		$rhIntroCameraCtrlP.unbind();

		$player1.setPrivateCameraView( $null_entity, 0 );
		$player1.cinematic( 0, 0 );
		$player1.enableEyeFocus();
		$player1.setBlendFrames( ANIMCHANNEL_HEAD, 0 );
		$player1.setBlendFrames( ANIMCHANNEL_TORSO, 0 );
		$player1.setBlendFrames( ANIMCHANNEL_LEGS, 0 );
		PlayCycle_Blend( $player1, ANIMCHANNEL_HEAD, "roadhouse_idle", 0 );
		PlayCycle_Blend( $player1, ANIMCHANNEL_TORSO, "roadhouse_idle", 0 );
		PlayCycle_Blend( $player1, ANIMCHANNEL_LEGS, "roadhouse_idle", 0 );
	}
	
	void IntroSinkTurnOn() {
		sys.wait( 10.25 );
		thread BathMSinkHotKnobToggle();
	}
	
	void CasinoDaltonIdle() {
		while ( true ) {
			sys.wait( 8 + sys.random( 10 ) );
			SpeechTransition_Blend( $rhDalton, "rh_drink_beer_dalton", "rh_idle_dalton", 12 );
		}
	}
	
	void CasinoChuckIdle() {
		while ( true ) {
			sys.wait( 8 + sys.random( 10 ) );
			SpeechTransition_Blend( $rhChuck, "rh_drink_beer_chuck", "rh_idle_chuck", 12 );
		}
	}
	
	void CasinoGrandfatherIdle() {
		float animNum;
		string animName;
		
		while ( true ) {
			sys.wait( 8 + sys.random( 10 ) );
			
			animNum = int( sys.random( 3 ) );
			
			if ( animNum == 0 ) {
				animName = "rh_idleb_grandfather";
			} else if ( animNum == 1 ) {
				animName = "rh_idlec_grandfather";
			} else if ( animNum == 2 ) {
				animName = "rh_idled_grandfather";
			}
			
			SpeechTransition_Blend( $rhGrandfather, animName, "rh_idle_grandfather", 36 );
		}
	}
	
	void CasinoPickUpTools() {
		$casinoWrenchTrigger.disable(); //disable wrench pickup
		$rhTools.hide();
		$player1.unlockWeapon( 1 );
	}
	
	void CasinoSetup() {
		//set skins to disable impacts
		$rhChuck.setSkin( "skins/characters/chuck_roadhouse_casino.skin" );
		$rhDalton.setSkin( "skins/characters/dalton_roadhouse_casino.skin" );
		
		//remove grandfather hallway clip
		$rhGrandfatherClip1.remove();
		$rhGrandfatherClip2.remove();
		
		$rhGrandfatherHallwayTrigger.remove(); //trigger that starts grandfather conversation
		$Conversation2.remove(); //trigger that starts bar conversation
		
		$casinoWrenchTrigger.enable(); //enable wrench pickup
		
		$player1.setBlendFrames( ANIMCHANNEL_TORSO, 0 );
		$player1.setBlendFrames( ANIMCHANNEL_LEGS, 0 );
		sys.waitFrame();
		PlayCycle_Blend( $player1, ANIMCHANNEL_TORSO, "roadhouse_idle", 48 );
		PlayCycle_Blend( $player1, ANIMCHANNEL_LEGS, "roadhouse_idle", 48 );
		
		gChuckDaltonBusy = 1; //disallow chuck/dalton comments
		
		//setup grandfather beer in hand and idle
		$rhGrandfather.setBlendFrames( ANIMCHANNEL_LEGS, 0 );
		$rhGrandfather.playCycle( ANIMCHANNEL_LEGS, "rh_idle_grandfather" );
		$rhGrandfatherBeer.moveToJoint( $rhGrandfather, "Rattach_gun" );
		$rhGrandfatherBeer.setAngles( $rhGrandfather.getJointAngle( $rhGrandfather.getJointHandle( "Rattach_gun" ) ) + '10 0 -83' );
		$rhGrandfatherBeer.bindToJoint( $rhGrandfather, "Rattach_gun", 1 );
		
		$rhAbductEmitter.remove();
		
		thread CasinoGrandfatherIdle();
		thread CasinoDaltonIdle();
		thread CasinoChuckIdle();
		
		$rhLightSwitch10Base.guiEvent( "TurnOn" ); //enable light switch near grandfather
	}
	
	void main() {
		g_CasinoMode = sys.getcvarFloat( "g_casino" );
		
		SetEntityIDs();
		SetGlobalShaderParms();
		ShipSetup();
		BathroomSetup();
		RHLightSetup();
		StoolSetup();
		JukeboxStart();
		WaterHeaterSetup();
		thread NPCSetup();
		thread WaterHeaterRun();
		thread FanSpin( $fan1Blades, 0.0 );
		thread FanSpin( $fan2Blades, 0.2 );
		
		if ( !g_CasinoMode ) {
			sys.trigger( $rhLevelStartSoundFade );
			PlayerSetup();
			QuickStartMirrorControl();
			IntroMusicPlay();
			TommyCanSpeak();
			thread ThunderSoftStart();
			thread WolfHowlRun();
			thread DogBarkRun();
			thread CarPassBy();
			thread ToiletBlow();
		} else {		
			CasinoSetup();
			IntroMusicPlay();
		}
	}
}
