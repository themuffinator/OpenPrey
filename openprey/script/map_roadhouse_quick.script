		thread SpeechTransition_Blend( $rhChuck, "rh_drink_beer_chuck", "rh_idle_chuck", 12 );
		
		//Jenny "I'm Cherokee, Tommy. Just like you.  You should be proud of that."
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_HEAD, "jn_roadhouse_imcherokee", 6 );
		sys.waitForSilence( $rhGirlfriend.getHead(), 0 );
		
		WaitDistanceJen( 0, 2, 1 );
		
		$rhGrandfather.overrideAnim( ANIMCHANNEL_HEAD );
		thread SpeechTransition_Blend( $rhGrandfather, "rh_idleb_grandfather", "rh_idle_grandfather", 36 ); //grandfather drinking
		
		//Tommy "Look, I know the tribe's important  to you. It's just... it's never meant anything to me."
		$player1.startSoundShader( "rh_conv6_tom07", SND_CHANNEL_VOICE );
		sys.waitForSilence( $player1, 0 );
						
		thread Conversation7();
	}
	
	void Conversation5JenExit() {		
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_LEGS, "rh_ringout_to_jenny", 12 );
		sys.wait( $rhGirlfriend.animLength( ANIMCHANNEL_LEGS, "rh_ringout_to_jenny" ) );
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_LEGS, "rh_ringout_idle_jenny", 12 );
		sys.wait( $rhGirlfriend.animLength( ANIMCHANNEL_LEGS, "rh_ringout_idle_jenny" ) );
		thread SpeechTransition_Blend( $rhGirlfriend, "rh_armsfolded_to_jenny", "rh_armsfolded_idle_jenny", 12 );
		
		//Jen "Wolves.  Something spooked them."
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_HEAD, "jn_roadhouse_wolves", 6 );
		$rhGirlfriend.lookAt( $rhChuck, 5 );
		sys.waitForSilence( $rhGirlfriend.getHead(), 0.0 );
		
		TommyCanSpeak();
		
		$rhGirlfriend.lookAt( $player1, -1 );
		
		sys.wait( 1 );
		thread Conversation6();
	}
	
	void Conversation5() {
		sys.wait( 2 );
		WaitPlayerNearBar( 0 );
		TommyQuiet( FALSE );
		thread Conversation5JenExit();
		$rhWolfWhineSpeaker1.On();
		sys.wait( 6 );
		
		thread SpeechTransition_Blend( $rhDalton, "rh_drink_beer_dalton", "rh_idle_dalton", 12 );
		
		//Grandfather "The Ani-Waya sense the coming of the storm."
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_HEAD, "gf_roadhouse_theaniwaya", 6 );
		sys.waitForSilence( $rhGrandfather.getHead(), 0.25 );
		
		//Chuck "Ani-what?"
		thread SpeechTransition_Blend( $rhChuck, "rh_keepm_chuck", "rh_idle_chuck", 24 );
		PlayAnim_Blend( $rhChuck, ANIMCHANNEL_HEAD, "ch_roadhouse_aniwhat", 6 );
		$rhChuck.lookAt( $rhGrandfather, 5 );
		sys.waitForSilence( $rhChuck.getHead(), 0.65 );
	}
	
	void Conversation4() {
		TommyQuiet( FALSE );
		
		PlayCycle_Blend( $rhGrandfather, ANIMCHANNEL_LEGS, "rh_idle_talk_grandfather", 32 );
		
		//Grandfather "Jen loves you, you know."
		$rhGrandfather.lookAt( $player1, -1 );
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_HEAD, "gf_roadhouse_jenloves", 6 );
		sys.waitForSilence( $rhGrandfather.getHead(), 0.25 );
		
		if ( CheckDistanceGF() ) {
			//Tommy "She has a helluva way of showing it."
			$player1.startSoundShader( "rh_conv4_tom02", SND_CHANNEL_VOICE );
			sys.waitForSilence( $player1, 0.25 );
		}
		
		WaitDistanceGF( 0, 2, 1 );
		
		//Grandfather "She is Cherokee. She is  bound to this land. Asking her to leave is  asking her to give up a part of her soul."
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_HEAD, "gf_roadhouse_sheis", 6 );
		sys.wait( 0.25 );
		$rhGrandfather.lookAt( $player1, 0 );
		$rhGrandfather.disableEyelook();
		sys.wait( 1.75 );
		$rhGrandfather.lookAt( $player1, -1 );
		$rhGrandfather.enableEyelook();
		sys.waitForSilence( $rhGrandfather.getHead(), 0 );
		
		if ( CheckDistanceGF() ) {
			//Tommy "But doesn't she want something better than this?"
			$player1.startSoundShader( "rh_conv4_tom04", SND_CHANNEL_VOICE );
			sys.waitForSilence( $player1, 0.1 );
		}
		
		WaitDistanceGF( 0, 2, 1 );
				
		//Grandfather "To be among one's own  people, to truly know where you belong... if  there is something better in this life, I have  not seen it. "
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_HEAD, "gf_roadhouse_tobe", 6 );
		sys.waitForSilence( $rhGrandfather.getHead(), 0.25 );
		
		if ( CheckDistanceGF() ) {
			//Tommy "That's because you never left."
			$player1.startSoundShader( "rh_conv4_tom06", SND_CHANNEL_VOICE );
			sys.waitForSilence( $player1, 0 );
		}
		
		TommyCanSpeak();
		
		PlayCycle_Blend( $rhGrandfather, ANIMCHANNEL_LEGS, "rh_idle_grandfather", 32 );
		
		$rhGrandfather.lookAt( $null_entity, 0 );
		
		thread Conversation5();
	}
	
	void Conversation4Distance() {				
		float startTime = sys.getTime();
		
		while ( $rhGrandfather.distanceTo( $player1 ) > 96 ) {
			sys.wait( 0.1 );
			if ( sys.getTime() - startTime > 50 ) {
				thread Conversation5();
				return;
			}
		}
		
		thread Conversation4();
	}
		
	void PickUpTools() {
		$rhTools.hide();
		$rhWrenchPickup.On();
		
		string gShowHud = sys.getcvar( "g_showHud" );
		sys.setcvar( "g_showHud", 0 );
		$player1.unlockWeapon( -1 ); //wrench raise
		sys.wait( 1 );
		$player1.lockWeapon( 1 ); //wrench lower
		sys.wait( 1 );
		sys.setcvar( "g_showHud", gShowHud );
		PlayCycle_Blend( $player1, ANIMCHANNEL_TORSO, "roadhouse_idle", 12 );
		PlayCycle_Blend( $player1, ANIMCHANNEL_LEGS, "roadhouse_idle", 12 );
	}
	
	void Conversation3() {		
		WaitDistanceJen( 1, 0, 0 );
		
		TommyQuiet( FALSE );
				
		thread SpeechTransition_Blend( $rhGirlfriend, "rh_lean_to_armsfolded_jenny", "rh_lean_idle_jenny", 24 );
		
		//Tommy "What's up babe?"
		$player1.startSoundShader( "rh_conv3_tom01", SND_CHANNEL_VOICE );
		sys.waitForSilence( $player1, 0 );
		
		WaitDistanceJen( 0, 2, 1 );
		
		//Girlfriend "Did you come in here for a drink, or to dump your dirty tools on my nice clean bar?"
		$rhGirlfriend.lookAt( $player1, -1 );
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_HEAD, "jn_roadhouse_didyou", 6 );
		sys.waitForSilence( $rhGirlfriend.getHead(), -0.1 );
		
		//wait for player to pickup tools	
		WaitDistanceTools( 2, 1 );
		thread PickUpTools();
		
		$rhGrandfather.overrideAnim( ANIMCHANNEL_HEAD );
		//thread SpeechTransition_Blend( $rhGrandfather, "rh_idlec_grandfather", "rh_idle_grandfather", 36 ); //grandfather looking around
		
		//Tommy "Sorry, babe."
		$player1.startSoundShader( "rh_conv3_tom03", SND_CHANNEL_VOICE );
		sys.waitForSilence( $player1, 0 );
		
		thread SpeechTransition_Blend( $rhGirlfriend, "rh_armsfolded_from_jenny", "rh_wipe_idle_jenny", 12 );
		
		TommyCanSpeak();
		
		sys.wait( 4 );
		
		WaitPlayerNearBar( 0 );
		TommyQuiet( FALSE );
		
		//Dalton "Hey, Pocahontas!  How about a couple more beers over here?"
		thread SpeechTransition_Blend( $rhDalton, "rh_heypoc_dalton", "rh_idle_dalton", 24 );
		PlayAnim_Blend( $rhDalton, ANIMCHANNEL_HEAD, "dl_roadhouse_heypocahontas", 6 );
		$rhDalton.lookAt( $rhGirlfriendLookAt, 5 );
		sys.wait( 0.5 );		
		$rhGirlfriend.lookAt( $rhDalton, 0 );
		sys.waitForSilence( $rhDalton.getHead(), -2.75 );
		
		$rhGirlfriend.lookAt( $player1, 2 );
		
		//Jenny "Sigh" gets new beers
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_HEAD, "jn_roadhouse_sighs", 2 );
		thread SpeechTransition_Blend( $rhGirlfriend, "rh_servebeers_jenny", "rh_wash_idle_jenny", 12 );
		sys.waitForSilence( $rhGirlfriend.getHead(), 1 );
				
		//Chuck "Keep'em coming, girl."
		thread SpeechTransition_Blend( $rhChuck, "rh_keepm_chuck", "rh_idle_chuck", 24 );
		PlayAnim_Blend( $rhChuck, ANIMCHANNEL_HEAD, "ch_roadhouse_keepem", 6 );
		$rhChuck.lookAt( $rhGirlfriendLookAt, 5 );
		sys.waitForSilence( $rhChuck.getHead(), 0 );
				
		TommyCanSpeak();
		
		sys.wait( 2 );
		
		thread Conversation4Distance();
		
		sys.wait( 1 );
		
		if ( !gChuckDaltonBusy ) {
			gChuckDaltonBusy = 1;
			thread SpeechTransition_Blend( $rhChuck, "rh_idlecheers_chuck", "rh_idle_chuck", 24 );
			SpeechTransition_Blend( $rhDalton, "rh_idlecheers_dalton", "rh_idle_dalton", 24 );
			gChuckDaltonBusy = 0;
		}
	}
	
	void Conversation2JenExit() {
		sys.wait( 2.25 );
		
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_LEGS, "rh_ringout_to_jenny", 12 );
		sys.wait( $rhGirlfriend.animLength( ANIMCHANNEL_LEGS, "rh_ringout_to_jenny" ) );
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_LEGS, "rh_ringout_idle_jenny", 12 );
