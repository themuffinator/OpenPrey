		//Chuck "Hey, you sell any of that red indian shit?  My wife loves that turquoise crap."
		thread SpeechTransition_Blend( $rhChuck, "rh_yousell_chuck", "rh_idle_chuck", 24 );
		thread SpeechTransition_Blend( $rhDalton, "rh_drink_beer_dalton", "rh_idle_dalton", 12 );
		
