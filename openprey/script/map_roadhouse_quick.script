		thread ShipGuideTrack( $rhGrandfather, 1, '0 0 0' );
		ShipLightMove( $rhGrandfather, 1, 1 );
		thread ShipLightChangeColors( 1, FALSE );
		PlayAnim_Blend( $rhGrandfather, ANIMCHANNEL_LEGS, "gf_roadhouse_suckedout", 24 );
		
		sys.wait( 2 );
		
		//Tommy "Grandfather!"
