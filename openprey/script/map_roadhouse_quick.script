	float gSink1_1WaterDir = DOWN,
		  gSink1_2WaterDir = DOWN,
		  gSink2_1WaterDir = DOWN,
		  gSink2_2WaterDir = DOWN;
	
	void BathSinkSetWaterDir( float index0, float index1, float value ) {
		if ( index0 == 1 ) {
			if ( index1 == 1 ) { gSink1_1WaterDir = value; }
			else if ( index1 == 2 ) { gSink1_2WaterDir = value; }
		}
		else if ( index0 == 2 ) {
			if ( index1 == 1 ) { gSink2_1WaterDir = value; }
			else if ( index1 == 2 ) { gSink2_2WaterDir = value; }
		}
	}
	
	float BathSinkGetWaterDir( float index0, float index1 ) {
		if ( index0 == 1 ) {
			if ( index1 == 1 ) { return gSink1_1WaterDir; }
			else if ( index1 == 2 ) { return gSink1_2WaterDir; }
		}
		else if ( index0 == 2 ) {
			if ( index1 == 1 ) { return gSink2_1WaterDir; }
			else if ( index1 == 2 ) { return gSink2_2WaterDir; }
		}
	}
	
	float gSink1_1ThreadRunning = 0,
		  gSink1_2ThreadRunning = 0,
		  gSink2_1ThreadRunning = 0,
		  gSink2_2ThreadRunning = 0;
	
	void BathSinkSetThreadRunning( float index0, float index1, float value ) {
		if ( index0 == 1 ) {
			if ( index1 == 1 ) { gSink1_1ThreadRunning = value; }
			else if ( index1 == 2 ) { gSink1_2ThreadRunning = value; }
		}
		else if ( index0 == 2 ) {
			if ( index1 == 1 ) { gSink2_1ThreadRunning = value; }
			else if ( index1 == 2 ) { gSink2_2ThreadRunning = value; }
		}
	}
	
	float BathSinkGetThreadRunning( float index0, float index1 ) {
		if ( index0 == 1 ) {
			if ( index1 == 1 ) { return gSink1_1ThreadRunning; }
			else if ( index1 == 2 ) { return gSink1_2ThreadRunning; }
		}
		else if ( index0 == 2 ) {
			if ( index1 == 1 ) { return gSink2_1ThreadRunning; }
			else if ( index1 == 2 ) { return gSink2_2ThreadRunning; }
		}
	}
	
	entity BathSinkGetWater( float index0, float index1 ) {
		if ( index0 == 1 ) {
			if ( index1 == 1 ) { return $rhBathMSinkWaterBasin; }
			else if ( index1 == 2 ) { return $rhBathMSink2WaterBasin; }
		}
		else if ( index0 == 2 ) {
			if ( index1 == 1 ) { return $rhBathFSinkWaterBasin; }
			else if ( index1 == 2 ) { return $rhBathFSink2WaterBasin; }
		}
	}
	
	//Updates bathroom water level for sinks
	void BathSinkUpdateWaterLevel( float index0, float index1 ) {
		entity water = BathSinkGetWater( index0, index1 );
		
		float waitTime = 0.1,
			  waterDirection,
			  distance = 0.005;
		
		vector waterPos = water.getOrigin();
		
		float waterPosLowest = waterPos_z,
			  waterPosDrainTop = waterPos_z + 1.625,
			  waterPosLowerBowlTop = waterPos_z + 2.45,
			  waterPosHighest = waterPos_z + 5;
			  											
		while ( true ) {
			waterDirection = BathSinkGetWaterDir( index0, index1 );
			
			if ( waterDirection == DOWN && waterPos_z == waterPosLowest ) { //water at lowest position
				break;
			} else {
				if ( waterPos_z >= waterPosLowest && waterPos_z < waterPosDrainTop ) { //water in drain
					distance = 0.75 * sys.getFrameTime();
				} else if ( waterPos_z >= waterPosDrainTop && waterPos_z < waterPosLowerBowlTop ) { //water in lower part of bowl
					distance = 0.125 * sys.getFrameTime();
				} else { //water above lower part of bowl
					distance = 0.375 * sys.getFrameTime();
				}
				
				//cap so water doesn't go above waterPosHighest
				if ( waterDirection == UP && ( waterPos_z + distance ) > waterPosHighest ) {
					distance = waterPosHighest - waterPos_z;
				} else if ( waterDirection == DOWN && ( waterPos_z - distance ) < waterPosLowest ) {
					distance = waterPos_z - waterPosLowest;
				}
				
				if ( distance > 0 ) {				
					if ( waterDirection == UP ) {
						waterPos_z += distance;
					} else {
						waterPos_z -= distance;
					}
					
					water.setOrigin( waterPos );
				}
			}

			sys.waitFrame();
		}
		
		BathSinkSetThreadRunning( index0, index1, FALSE );
	}
	
	//Rotates bathroom knobs and controls water particles / sounds
	//knob is the knob currently being used.
	void BathSinkKnobToggle( entity gui, entity knob, entity knob2, entity waterFaucet, entity sound, float index0, float index1 ) {		
		if ( knob.getFloatKey( "isRunning" ) == 0 ) {
			knob.setKey( "isRunning", 1 );
			
			//swap gui hand press anim
			if ( gui.getKey( "pressAnim" ) == "press_left" ) {
				gui.setKey( "pressAnim", "press_right" );
			} else {
				gui.setKey( "pressAnim", "press_left" );
			}
						
			if ( knob.getKey( "currentState" ) == "off" ) {				
				knob.startSound( "snd_turn", SND_CHANNEL_ANY, 1 );
				if ( knob.getKey( "reverseRot" ) ) {
					knob.rotateOnce( '0 60 0' );
				} else {
					knob.rotateOnce( '0 -60 0' );
				}
				knob.setKey( "currentState", "on" );
				
				if ( knob2.getKey( "currentState" ) == "off" ) { //check that the other handle isn't turned on
					BathSinkSetWaterDir( index0, index1, UP );
					
					thread interpolateShaderParm( waterFaucet, 5, 0, 1.25, 0.1 ); //fade in water stream
					thread fadeInEnt( waterFaucet, '0.2 0.2 0.225', 0.1 );
				}
				
				sound.On();
				
				//run update water level thread if not running
				if ( BathSinkGetThreadRunning( index0, index1 ) == FALSE ) {
					BathSinkSetThreadRunning( index0, index1, TRUE );
					thread BathSinkUpdateWaterLevel( index0, index1 );
				}
				
				sys.waitFor( knob );
			} else { //currentState == "on"
				knob.startSound( "snd_turn", SND_CHANNEL_ANY, 1 );
				if ( knob.getKey( "reverseRot" ) ) {
					knob.rotateOnce( '0 -60 0' );
				} else {
					knob.rotateOnce( '0 60 0' );
				}
				sys.waitFor( knob );
				knob.setKey( "currentState", "off" );
				
				if ( knob2.getKey( "currentState" ) == "off" ) { //check that the other handle isn't turned on
					BathSinkSetWaterDir( index0, index1, DOWN );
					
					thread interpolateShaderParm( waterFaucet, 5, 1.25, 0, 0.1 ); //fade out water stream
					thread fadeOutEnt( waterFaucet, '0.2 0.2 0.225', 0.1 );
				}
				
				sound.Off();
				
				sys.wait( 0.1 );
			}
			
			knob.setKey( "isRunning", 0 );
		}
	}
	
