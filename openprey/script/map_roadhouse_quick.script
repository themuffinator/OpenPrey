	//Random toilet sounds
	void ToiletBlow() {
		float currentToilet;
		
		while ( !gAbducting ) {
			sys.wait( 20 + sys.random( 20 ) );
			
			currentToilet = int( sys.random( 3 ) );
			if ( currentToilet == 0 ) {
				$rhBathFToiletBlow.On();
			}
			else if ( currentToilet == 1 ) {
				$rhBathFToilet2Blow.On();
			}
			else {
				$rhBathMToiletBlow.On();
			}
		}
	}
	
	//Handles the water and sound for flushing so the handle can be independent
	void BathToiletFlushWater( entity handle, entity flushSound, entity waterCtrlP, entity water ) {
		if ( handle.getFloatKey( "isFlushing" ) == 0 ) {
			handle.setKey( "isFlushing", 1 );
			flushSound.On();
			TimeTweak( waterCtrlP, 1, 1, 7 );
			waterCtrlP.move( DOWN, 6 );
			
			thread interpolateShaderParm( water, 5, 0.25, 1.5, 4 );
			thread crossFadeEnt( water, '0.15 0.15 0.15', '0.35 0.35 0.35', 4 );
			thread interpolateShaderParm( water, 6, 0, -3, 7 );
			
			sys.waitFor( waterCtrlP );
			sys.wait( 0.5 );
			TimeTweak( waterCtrlP, 1, 3, 6 );
			waterCtrlP.move( UP, 6 );
			
			thread interpolateShaderParm( water, 5, 1.5, 0.25, 6 );
			thread crossFadeEnt( water, '0.35 0.35 0.35', '0.15 0.15 0.15', 4 );
			
			sys.waitFor( waterCtrlP );
			handle.setKey( "isFlushing", 0 );
		}
	}
	
	//Toilet flush sounds / movement
	void BathToiletFlush( entity handle, entity handleSound, entity flushSound, entity waterCtrlP, entity water ) {		
		if ( handle.getFloatKey( "isRunning" ) == 0 ) {
			handle.setKey( "isRunning", 1 );
			
			thread BathToiletFlushWater( handle, flushSound, waterCtrlP, water );
		
			handleSound.On();
			handle.rotateOnce( '0 0 45' );
			sys.waitFor( handle );
			handle.rotateOnce( '0 0 -45' );
			
			sys.waitFor( handle );
			handle.setKey( "isRunning", 0 );
		}
	}
	
