	//Main ship entry function
	void ShipEntry() {
		thread PlayMapMusic( "snd_roadhouse_abduction_c", false, MUS_TRANSITION_OVERLAP );
		
		thread TruckSmash();
		
		thread RoofShakePlaySounds();
		sys.wait( 4 );
				
		thread PowerOutage();		
		sys.wait( 1.5 );
		
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_HEAD, "jn_roadhouse_screamwhat", 6 );
		sys.wait( 0.5 );

		thread RoofRip();
		ShipShow();
		ShipDustStart();
		RemoveStoolGUIs();
		
		//fade in ambient light for abduction
		$rhShipAmbientLight1.On();
		thread fadeInEnt( $rhShipAmbientLight1, $rhShipAmbientLight1.getVectorKey( "_color" ), 4 );
		
		thread ShipDissolve();
		
		sys.wait( 2 );
		
		thread ShipMoveDown();
	
		sys.wait( 5 );
		
		thread ShipEntryDialog();
	
		ShipRemoveAll();
	}
	
