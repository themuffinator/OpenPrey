	//Smashes ceiling just before truck comes through
	void TruckCeilingSmash() {
		sys.trigger( $rhLightBulb10_1Sparks );
		$rhTruckCeilingBoards.show();
		sys.trigger( $rhTruckCeilingChunkStatic1 );
		sys.trigger( $rhTruckCeilingChunkStatic2 );
		sys.trigger( $rhTruckCeilingChunkStatic3 );
		sys.trigger( $rhTruckCeilingChunkStatic4 );
		sys.trigger( $rhTruckCeilingChunkStatic5 );
		sys.waitFrame();
		$rhLightBulb10_1.remove();
		$rhLightBulb10_1b.remove();
		$rhLightFlare10_1.remove();
		$rhLight10_1.On();
		$rhLight10_1.setColor( 2, 2, 2 );
		sys.wait( 0.2 );
		$rhLight10_1.setColor( 0, 0, 0 );
		sys.wait( 0.2 );
		$rhLight10_1.setColor( 2, 2, 2 );
		sys.wait( 0.3 );
		$rhLight10_1.remove();
		sys.waitFrame();
		$rhLightSwitch10Relay.findTargets();
	}
	
