	void StoolSetNextRot( entity gui ) {		
		if ( int( sys.random( 2 ) ) ) {
			gui.setKey( "nextRot", Vec3Set( 0, sys.random( 135 ) + 360, 0 ) );
			gui.setKey( "pressAnim", "press_right" );
		} else {
			gui.setKey( "nextRot", Vec3Set( 0, sys.random( 135 ) - 360, 0 ) );
			gui.setKey( "pressAnim", "press_left" );
		}
	}
	
	//sets time for stool spins
	void StoolSetup() {
		float rotAccel = 0.1,
			  rotDecel = 1.4,
			  rotTime = 1.5;
			  		
		TimeTweak( $rhStool1Top, rotAccel, rotDecel, rotTime );
		TimeTweak( $rhStool2Top, rotAccel, rotDecel, rotTime );
		TimeTweak( $rhStool3Top, rotAccel, rotDecel, rotTime );
		TimeTweak( $rhStool7Top, rotAccel, rotDecel, rotTime );
		TimeTweak( $rhStool10Top, rotAccel, rotDecel, rotTime );
		StoolSetNextRot( $rhStool1GUI );
		StoolSetNextRot( $rhStool2GUI );
		StoolSetNextRot( $rhStool3GUI );
		StoolSetNextRot( $rhStool7GUI );
		StoolSetNextRot( $rhStool10GUI );
	}
	
	void StoolSpin( entity gui, entity stoolTop ) {
		if ( !stoolTop.getFloatKey( "isRunning" ) ) {
			stoolTop.setKey( "isRunning", 1 );
			
			stoolTop.startSound( "snd_squeek", SND_CHANNEL_ANY, 1 );
			
			vector rotVec;
			rotVec = gui.getVectorKey( "nextRot" );
						
			stoolTop.rotateOnce( rotVec );
			sys.waitFor( stoolTop );
			
			StoolSetNextRot( gui );
			
			sys.waitFrame();
			
			stoolTop.setKey( "isRunning", 0 );
		}
	}
	
