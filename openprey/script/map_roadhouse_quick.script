	//Main function for ripping the roof off roadhouse
	void RoofRip() {
		sys.trigger( $rhShipFuncPortal );
		
		sys.trigger( $rhRoofPlanksShow );
		sys.waitFrame(); //needed because planks aren't shown immediately
		$rhRoofSolid.hide();
		
		thread ThunderLoudStart();
		thread BuildingCrackSounds();
		
		thread RoofCrackPlaySounds();
				
		RoofRattlePlanks();
		
		sys.wait( 1.5 );
		thread RoofBreakPlaySounds();
		
		//turn on ship lights just before removing planks
		thread ShipPulseLights();
		thread ShipPulseGreenLights();
		RoofRemovePlanks();
		
		gRoofPlanksRattle = 0;
	}
	
	//Moves ship lights that pick items up
	void ShipLightMove( entity target, float isNPC, float lightNumber ) {
		entity lightSource = sys.getEntity( "rhShipProjLightMiddleSource" + lightNumber );
		entity beamGrabSpeaker = sys.getEntity( "rhShipProjLightMiddleBeamGrab" + lightNumber );
		
		vector vecToTarget,
			   targetAngle,
			   targetOrigin,
			   sourceOrigin = lightSource.getVectorKey( "origin" );
			   
		if ( !isNPC ) {
			targetOrigin = target.getWorldOrigin();
		} else {
			targetOrigin = target.getJointPos( target.getJointHandle( "waist" ) );		
		}
			   		
		vecToTarget = VecSubtract( targetOrigin, sourceOrigin );
		targetAngle = sys.VecToAngles( vecToTarget );
		targetAngle = anglemod360( targetAngle );
		
		lightSource.rotateTo_world( targetAngle );
		sys.waitFor( lightSource );
		
		beamGrabSpeaker.On();
	}
	
	//Changes colors briefly for lights picking up items
	void ShipLightChangeColors( float lightNumber, float fadeFromBlack ) {
		entity cone = sys.getEntity( "rhShipProjLightMiddleCone" + lightNumber ),
			   coneVFP = sys.getEntity( "rhShipProjLightMiddleCone" + lightNumber + "VFP" ),
			   light = sys.getEntity( "rhShipProjLightMiddle" + lightNumber );
		
		vector color1 = '0.3 0.53 0.41',
			   color2 = '1.09 2 1.5294',
			   color3 = color1;
			   
		if ( fadeFromBlack ) {
			color1 = '0 0 0';
		}
		
		thread crossFadeEnt( cone, color1, color2, 0.2 );
		thread interpolateShaderParm( coneVFP, 6, 1, 18, 0.2 );
		thread crossFadeEnt( light, color1, color2, 0.2 );
		sys.wait( 0.5 );
		thread crossFadeEnt( cone, color2, color3, 1.0 );
		thread interpolateShaderParm( coneVFP, 6, 18, 1, 1.0 );
		thread crossFadeEnt( light, color2, color3, 1.0 );
	}
	
	//updates angles so the particle effect for abduction always faces towards the ship
	void AbductionEffectSetAngles() {
		vector vecToTarget,
			   targetAngle,
			   viewAngles;
		
		while ( true ) {	
			vecToTarget = VecSubtract( $rhShipCollectorNode.getWorldOrigin(), $rhAbductEmitter.getWorldOrigin() );
			targetAngle = sys.VecToAngles( vecToTarget );
			targetAngle = anglemod360( targetAngle );
			targetAngle_x += 90; //$rhAbductEmitter faces up by default
						
			$rhAbductEmitter.setAngles( targetAngle );
			sys.waitFrame();
		}
	}
	
	//starts screen effect and particles for abduction
	void AbductionScreenEffect() {
		$player1.setOverlayMaterial( "textures/special/abduction_screenfx", false );
		thread CrossFadeOverlayColor( $player1, '0 0 0', 0, '0 0 0', 1, 4 );
				
		sys.fadeOut( '1 1 1', 8 );
		
		thread AbductionEffectSetAngles();
		$rhAbductEmitter.setOrigin( $player1.getOrigin() );
		$rhAbductEmitter.bindPosition( $player1 );
		sys.trigger( $rhAbductEmitter );
		fadeInEnt( $rhAbductEmitter, '1 1 1', 8 );
		sys.fadeOut( '0 0 0', 0.5 );
	}
	
	void ShipRemovePlayer() {
		ShipLightMove( $player1, 0, 2 );
		thread ShipLightChangeColors( 2, FALSE );
		TimeTweak( $rhTommyBindCtrlP, 4, 0, 8 );
		
		thread ShipGuideTrack( $player1, 0, '0 0 64' );
		$rhTommyBind.bindattach( $player1, TRUE );
		
		sys.wait( 0.5 );		
		sys.trigger( $rhShipHunter2 );
		sys.wait( 0.2 );
		sys.trigger( $rhShipHunter1 );
		sys.wait( 0.3 );
		sys.trigger( $rhShipHunter3 );
		sys.wait( 1.0 );
		
		$rhTommyBindCtrlP.moveTo( $rhShipCollectorNode );
		
		thread AbductionScreenEffect();
		sys.wait( 1 );
		$player1.startSoundShader( "rh_player_scream", SND_CHANNEL_VOICE );
		sys.wait( 2 );
		sys.trigger( $rhLevelEndSoundFade );
		thread FadeMapMusic( MUS_SILENCE_DB, 4.5 );
		sys.setcvar( "g_roadhouseCompleted", 1 );
		sys.wait( 4.5 );
		sys.trigger( $rhEndLevel );
	}
	
	//Moves moveable from the bar to ship collector
	void ShipRemove1Node( string prefix, vector timeData1, float delay, float lightNumber ) {		
		entity entityToRemove = sys.getEntity( prefix ),
			   bindcontroller = sys.getEntity( prefix + "Bind" ),
			   ctrlP = sys.getEntity( prefix + "BindCtrlP" );
			   			   
		thread ShipGuideTrack( entityToRemove, 0, '0 0 0' );
		
		ShipLightMove( entityToRemove, 0, lightNumber );
		
		thread ShipLightChangeColors( lightNumber, FALSE );
		
		thread DissolveEntity( entityToRemove );
		
		if ( entityToRemove.getKey( "snd_remove" ) != "" ) {
			entityToRemove.startSound( "snd_remove", SND_CHANNEL_ANY, 1 );
		}
		sys.trigger( entityToRemove );
		bindcontroller.bindattach( entityToRemove, TRUE );
		sys.wait( delay );
		TimeTweak( ctrlP, timeData1_x, timeData1_y, timeData1_z );
		ctrlP.moveTo( $rhShipCollectorNode );	
		sys.waitFor( ctrlP );
	}
	
	//Moves moveable from the bar to a node, then to the ship collector
	void ShipRemove2Node( string prefix, entity node1, vector timeData1, vector timeData2, float delay, float lightNumber ) {
		entity entityToRemove = sys.getEntity( prefix ),
			   bindcontroller = sys.getEntity( prefix + "Bind" ),
			   ctrlP = sys.getEntity( prefix + "BindCtrlP" );
			   
		thread ShipGuideTrack( entityToRemove, 0, '0 0 0' );
		
		ShipLightMove( entityToRemove, 0, lightNumber );
		
		thread ShipLightChangeColors( lightNumber, FALSE );
		
		thread DissolveEntity( entityToRemove );
		
		if ( entityToRemove.getKey( "snd_remove" ) != "" ) {
			entityToRemove.startSound( "snd_remove", SND_CHANNEL_ANY, 1 );
		}
		sys.trigger( entityToRemove );
		bindcontroller.bindattach( entityToRemove, TRUE );
		sys.wait( delay );
		TimeTweak( ctrlP, timeData1_x, timeData1_y, timeData1_z );
		ctrlP.moveTo( node1 );
		sys.waitFor( ctrlP );
		
		TimeTweak( ctrlP, timeData2_x, timeData2_y, timeData2_z );
		ctrlP.moveTo( $rhShipCollectorNode );
		sys.waitFor( ctrlP );
		entityToRemove.remove();
	}
	
	//Makes arcadeGame nonsolid, then calls appropriate remove function
	void ArcadeGameRemove( entity arcadeGame, entity arcadeGameConsole, float lightNumber ) {
		arcadeGame.becomeNonSolid();
		thread ShipRemove2Node( arcadeGame.getName(), $rhGameNode1, '0.5 0.5 1.5', '2 2 6', 0.5, lightNumber );
		sys.wait( 2 );
		thread DissolveEntity( arcadeGameConsole );
	}
	
