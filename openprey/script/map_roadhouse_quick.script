	//Spins a fan until gFansSpin is set to 0
	void FanSpin( entity blades, float delay ) {
		TimeTweak( blades, 0, 0, 1 );
		
		if ( delay > 0.0 ) {
			sys.wait( delay );
		}
		
		while ( gFansSpin ) {
			blades.rotateOnce( '0 360 0' );
			sys.waitFor( blades );
			sys.waitPVS( blades );
		}
		
		float fanDecelTime = 7.5 + delay; //adds delay for an offset
		TimeTweak( blades, 0, fanDecelTime, fanDecelTime );
		blades.rotateOnce( '0 1440 0' );
		sys.waitFor( blades );
	}
	
	//Used in the roadhouse light pulsate sequence to change a lights color
	void LightColorChange( float newColorMultiplier, float fadeTime ) {
		float i,
		      j,
		      relayNumTargets;
		      			   
		entity lightRelay,
			   currentSwitch,
			   currentEnt;
		
		vector originalColor,
			   newColor;
			   
		string className;
		
		for ( i = 1; i <= 11; i++ ) {
			if ( currentSwitch = sys.getEntity( "rhLightSwitch" + i ) ) {
				if ( currentSwitch.getKey( "currentState" ) == "on" ) {
					lightRelay = sys.getEntity( "rhLightSwitch" + i + "Relay" );
					
					relayNumTargets = lightRelay.numTargets();
					for ( j = 0; j < relayNumTargets; j++ ) {
						if ( currentEnt = lightRelay.getTarget( j ) ) {
							className = currentEnt.getKey( "classname" );
							
							if ( className == "light" || className == "func_static" || className == "env_hanglight_bar" || className == "func_emitter" ) {
								originalColor = currentEnt.getVectorKey( "_color" );
								newColor = Vec3Set( originalColor_x * newColorMultiplier, originalColor_y * newColorMultiplier, originalColor_z * newColorMultiplier );
								thread crossFadeEnt( currentEnt, originalColor, newColor, fadeTime );
							}
						}
						
						if ( i == 1 || i == 8 ) {
							sys.waitFrame();
						}
					}
				}
			}
		}
	}
	
