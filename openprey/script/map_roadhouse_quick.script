	void DaltonPush() {
		$rhDaltonPlayerPush.time( 2.375 );
		$rhDaltonPlayerPush.move( EAST, 42 );
		
		$rhDaltonMovablePush.time( 2.375 );
		$rhDaltonMovablePush.move( EAST, 42 );
	}
	
	void DaltonFight() {
		$rhDaltonClip.remove(); //remove player clip
				
		thread DaltonPush();
		$rhDalton.lookAt( $player1, -1 );
		PlayAnim_Blend( $rhDalton, ANIMCHANNEL_LEGS, "rh_standtofight_dalton", 24 );
		sys.wait( 1 );
		//Dalton "All right then, chief. You want it?  Come get it!"
		PlayAnim_Blend( $rhDalton, ANIMCHANNEL_HEAD, "dl_roadhouse_allright", 6 );
		sys.wait( 1 );
		sys.wait( $rhDalton.animLength( ANIMCHANNEL_LEGS, "rh_standtofight_dalton" ) - 2 );
		$rhDalton.killbox(); //kill all movables in area
		sys.waitFrame();
		$rhDaltonPlayerPush.remove(); //remove player push clip
		$rhDaltonMovablePush.remove(); //remove movable push clip
		$rhDalton.becomeSolid();
		$rhDalton.allowMovement( 1 );
		
		if ( CheckSpawnId( $rhDalton, gDaltonID ) ) {			
			if ( EntIsAlive( $rhDalton ) ) {
				$rhDalton.followPath( "pathAttackPlayer" );
			}
		}
		
		TommyCanSpeak();
	
		$player1.unlockWeapon( 1 );
	}
	
