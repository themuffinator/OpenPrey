	//Handles flushing of the water to stay independent of the handle
	void BathUrinalFlushWater( entity handle, entity urinal, entity flushSound ) {
		if ( handle.getFloatKey( "isFlushing" ) == 0 ) {
			handle.setKey( "isFlushing", 1 );
			
			flushSound.On();
			thread fadeInEnt( urinal, '1 1 1', 1 );
			thread interpolateShaderParm( urinal, 6, 0, 1, 1 );
			sys.wait( 3 );
			thread interpolateShaderParm( urinal, 6, 1, 0, 1 );
			fadeOutEnt( urinal, '1 1 1', 1 );
			sys.wait( 1 );
			
			handle.setKey( "isFlushing", 0 );
		}
	}
	
	//handle movement, calls water flush
	void BathUrinalFlush( entity handle, entity urinal, entity flushSound, entity handleSound ) {		
		if ( handle.getFloatKey( "isRunning" ) == 0 ) {
			handle.setKey( "isRunning", 1 );
			
			handleSound.On();
			handle.rotateOnce( '0 0 -15' );
			sys.waitFor( handle );
			
			thread BathUrinalFlushWater( handle, urinal, flushSound );
			
			handle.rotateOnce( '0 0 15' );
			sys.waitFor( handle );
			
			handle.setKey( "isRunning", 0 );
		}
	}
	
