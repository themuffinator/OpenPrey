	void BarCounterOpenThread() {
		$rhBarCounter.startSound( "snd_open", SND_CHANNEL_ANY, 0 );
		
		entity target = $rhGrandfather,
			   source = $rhBarCounter;
		
		vector vecToTarget,
			   targetAngle,
			   targetOrigin,
			   sourceOrigin;
			   
		float targetJointHandle = target.getJointHandle( "Lattach_gun" ),
			  numFrames = 2.048 / sys.getFrameTime(),
			  i;
			   		
		for ( i = 0; i < numFrames; i++ ) {	
			targetOrigin = target.getJointPos( targetJointHandle ) + '6 0 8';
			sourceOrigin = source.getWorldOrigin();
			
			vecToTarget = VecSubtract( targetOrigin, sourceOrigin );
			targetAngle = sys.VecToAngles( vecToTarget );
			targetAngle = anglemod360( targetAngle );
			
			source.setAngles( Vec3Set( -targetAngle_x, 0, 0 ) );
			sys.waitFrame();
		}
		
		TimeTweak( $rhBarCounter, 0, 0.5, 0.5 );
		$rhBarCounter.rotateOnce( '5 0 0' );
		sys.waitFor( $rhBarCounter );
		TimeTweak( $rhBarCounter, 0.375, 0.375, 0.75 );
		$rhBarCounter.rotateOnce( '-5 0 0' );
	}
	
	void BarCounterOpen() {
		thread BarCounterOpenThread();
	}
	
	void BarCounterCloseThread() {
		TimeTweak( $rhBarCounter, 0.8, 0.0, 0.8 );
		$rhBarCounter.rotateTo( '0 0 0' );
		sys.waitFor( $rhBarCounter );
		$rhBarCounter.startSound( "snd_close", SND_CHANNEL_ANY, 0 );
		
		TimeTweak( $rhBarCounter, 0.1, 0.0, 0.1 );
		$rhBarCounter.rotateOnce( '2 0 0' );
		sys.waitFor( $rhBarCounter );
		$rhBarCounter.rotateOnce( '-2 0 0' );
	}
	
	void BarCounterClose() {
		thread BarCounterCloseThread();
	}
	
