		thread DissolveEntity( $rhLightBulb1_3 );
		sys.wait( 0.5 );
		
		//dissolve vent and lights attached to it
		thread DissolveEntity( $rhLightBulb8_3 );
		thread DissolveEntity( $rhLightBulb1_10 );
