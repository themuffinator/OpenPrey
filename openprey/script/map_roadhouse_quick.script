		thread ShipLightChangeColors( 1, FALSE );
				
		thread DissolveEntity( $rhGrandfather );
		
		thread ShipGuideTrack( $rhGirlfriend, 1, '0 0 0' );
		PlayAnim_Blend( $rhGirlfriend, ANIMCHANNEL_LEGS, "suckedup",34 );
		sys.trigger( $rhGirlfriend );
		sys.wait( 5 );
		
		thread DissolveEntity( $rhGirlfriend );
	}
	
